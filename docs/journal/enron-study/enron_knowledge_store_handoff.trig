rcg:map {
    <https://example.test/enron-emails#caveat_eml_attachment_identity> a rc:KnownCaveat ;
        rdfs:label "EML attachments lack a separate attachment id" ;
        rc:caveatDescription "The EML attachment table has parent_doc_id, custodian, filename, mime_type, and size, but no separate attachment doc_id or native hash column in the observed schema." ;
        rc:impact "Use XML attachments when attachment-level identity, hashes, or native paths are needed." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#eml_attachments__custodian> a rc:Column ;
        rdfs:label "EML attachments custodian" ;
        rdfs:comment "Observed large_string column in eml_attachments. Full scan found 0 nulls and 151 distinct values." ;
        rc:columnName "custodian" ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:Custodian> .

    <https://example.test/enron-emails#eml_attachments__filename> a rc:Column ;
        rdfs:label "EML attachments filename" ;
        rdfs:comment "Observed large_string column in eml_attachments. Full scan found 0 nulls and 63448 distinct values." ;
        rc:columnName "filename" ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:AttachmentFileName> .

    <https://example.test/enron-emails#eml_attachments__mime_type> a rc:Column ;
        rdfs:label "EML attachments mime_type" ;
        rdfs:comment "Observed large_string column in eml_attachments. Full scan found 0 nulls and 14 distinct values." ;
        rc:columnName "mime_type" ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:MimeType> .

    <https://example.test/enron-emails#eml_attachments__size> a rc:Column ;
        rdfs:label "EML attachments size" ;
        rdfs:comment "Observed uint64 column in eml_attachments. Full scan found 0 nulls and 18022 distinct values." ;
        rc:columnName "size" ;
        rc:nullable false ;
        rc:physicalType rc:UBigInt ;
        rc:valueType <enron:FileSizeBytes> .

    <https://example.test/enron-emails#eml_messages__attachment_count> a rc:Column ;
        rdfs:label "EML messages attachment_count" ;
        rdfs:comment "Observed uint16 column in eml_messages. Full scan found 0 nulls and 161 distinct values." ;
        rc:columnName "attachment_count" ;
        rc:nullable false ;
