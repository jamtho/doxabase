        rc:bucketName "enron-emails" ;
        rc:credentialReference "local MinIO alias or workstation profile; credentials intentionally omitted" ;
        rc:endpointProfile "local MinIO endpoint profile; localhost:9000 in the current workstation environment" ;
        rc:layoutVerificationNote "Bucket listing was checked with mc, files were copied to a temp snapshot, and DuckDB/PyArrow full-file profiles were run on 2026-07-01." ;
        rc:layoutVerificationStatus rc:VerifiedByQueryLayout ;
        rc:locationKind "prefix" ;
        rc:pathStyleAccess true ;
        rc:pathTemplate "eml_attachments.parquet",
            "eml_messages.parquet",
            "xml_attachments.parquet",
            "xml_messages.parquet" ;
        rc:routeRole rc:CanonicalRoute,
            rc:CurrentRoute,
            rc:ProductionRoute ;
        rc:storageProtocol rc:S3CompatibleStorage ;
        rc:storageRoot "s3://enron-emails/" .

