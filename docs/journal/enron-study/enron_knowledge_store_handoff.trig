        rc:claimText "Among 1,227,255 overlapping message doc_ids, 1,226,990 EML/XML timestamps match within one second and 1,226,993 match on UTC day. The implausible date rows are shared rather than representation-specific." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_address_regex_coverage_deep> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_address_regex_incomplete>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "Regex email extraction finds top domains and internal/external hints, but many populated fields lack regex email tokens and some rows carry Exchange/X.500-style markers." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_analysis_views_define_populations> a rc:Claim ;
        rc:claimKind rc:InterpretationClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_analysis_population_views>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "The case-study store now records recommended logical populations for plausible-date messages, EML/XML overlap, EML-only blank-source rows, text-ready rows, sender-email coverage, attachment counts, and folder families." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_attachment_foreign_keys> a rc:Claim ;
        rc:claimKind rc:JoinClaim ;
        rc:claimTarget <https://example.test/enron-emails#eml_attachments>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_attachments>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "All EML attachment parent_doc_id values resolve to EML message doc_id, and all XML attachment parent_doc_id values resolve to XML message doc_id in the observed files." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked ;
        rc:proposedAssertion <https://example.test/enron-emails#relationship_eml_attachment_parent_doc_id_to_eml_doc_id>,
            <https://example.test/enron-emails#relationship_xml_attachment_parent_doc_id_to_xml_doc_id> .

    <https://example.test/enron-emails#claim_attachment_hash_extension_deep> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_attachment_hash_duplicates>,
            <https://example.test/enron-emails#eml_attachments>,
            <https://example.test/enron-emails#xml_attachments> ;
        rc:claimText "Normalized attachment extensions reveal mixed-case variants and blank extensions, while XML native_hash shows many duplicate-content attachment rows." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_attachment_heavy_tail_requires_robust_summaries> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_attachment_heavy_tail>,
            <https://example.test/enron-emails#eml_attachments>,
            <https://example.test/enron-emails#xml_attachments> ;
        rc:claimText "Message-level attachment rows reach 260, p999 is 33, and 4,525 messages have at least 10 attachments in both EML and XML attachment aggregations." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_body_top_derived> a rc:Claim ;
        rc:claimKind rc:TransformationClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_body_top_transformation>,
            <https://example.test/enron-emails#eml_messages__body>,
            <https://example.test/enron-emails#eml_messages__body_top> ;
        rc:claimText "body_top equals body in most rows but is shorter than body in 208,906 rows, supporting treatment as a derived top-level text surface rather than an independent raw field." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_communication_domain_coverage_network_pass> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_communication_domain_coverage>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "Regex domain extraction supports useful domain-level matrices, but none-class rows dominate both EML and XML. The none class means parser coverage is missing, not that no communication occurred." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_custodian_skew_requires_reporting> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_custodian_skew_and_body_coverage>,
            <https://example.test/enron-emails#eml_messages__custodian>,
            <https://example.test/enron-emails#xml_messages__custodian> ;
        rc:claimText "All 151 custodians appear in both EML and XML, but the largest custodian slices dominate row counts and body-text coverage varies substantially." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_date_outliers> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_date_plausibility>,
            <https://example.test/enron-emails#eml_messages__date>,
            <https://example.test/enron-emails#xml_messages__date_sent> ;
        rc:claimText "EML and XML timestamp fields include values outside 1997-2004; XML date_sent includes severe parse outliers from year 1316 through 9719." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_duplicates_cross_contexts> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_dedup_clusters_cross_context>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_attachments> ;
        rc:claimText "Duplicate message_id, body-hash, and XML attachment-hash clusters often cross custodians or folders, so deduplication is a global provenance-aware task." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_eml_only_blank_source_subset_deep> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_eml_only_blank_source_subset>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "The 7,132 EML rows absent from XML all have blank folder and blank source_file; they are concentrated in a small custodian subset and only 17 have attachments." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_empty_string_missingness> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_empty_strings>,
            <https://example.test/enron-emails#eml_messages> ;
        rc:claimText "EML recipient, subject, body, body_top, and folder columns are physically non-null but contain large empty-string populations that should be normalized for analysis." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_folder_families_have_semantics> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_folder_family_semantics>,
            <https://example.test/enron-emails#eml_messages__folder>,
            <https://example.test/enron-emails#xml_messages__location_uri> ;
        rc:claimText "Folder families such as all documents, calendar, discussion threads, contacts, sent, and blank have different body availability, attachment rates, date outlier counts, and custodian coverage." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_message_like_population_network_pass> a rc:Claim ;
        rc:claimKind rc:InterpretationClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_message_like_population>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "After plausible-date filtering and excluding calendar, contacts, and meetings, there are 980,561 EML rows; 714,325 have body text and 670,649 have body_top text. XML has 973,356 comparable message-like rows." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_monthly_calendar_spike_network_pass> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_monthly_calendar_spike>,
            <https://example.test/enron-emails#eml_messages__date>,
            <https://example.test/enron-emails#eml_messages__folder> ;
        rc:claimText "November 2002 is the largest plausible-date month in both representations, and 126,208 EML rows in that month come from the calendar folder family." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_query_cookbook_deep> a rc:Claim ;
        rc:claimKind rc:AccessClaim ;
        rc:claimTarget <https://example.test/enron-emails#eml_attachments>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_attachments>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "The query cookbook gives starting DuckDB query shapes for table registration, EML/XML comparison, date hygiene, attachment joins, sender domains, text surface choice, threading, and attachment type analysis." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_text_surface_readiness_deep> a rc:Claim ;
        rc:claimKind rc:TransformationClaim ;
        rc:claimTarget <https://example.test/enron-emails#ExtractTopLevelBodyText>,
            <https://example.test/enron-emails#caveat_text_surface_readiness>,
            <https://example.test/enron-emails#eml_messages__body>,
            <https://example.test/enron-emails#eml_messages__body_top> ;
        rc:claimText "body contains the original-message marker on 87,317 rows, while body_top contains none; body_top is blank on 539,162 rows compared with 494,515 blank body rows." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_threading_dedup_deep> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_threading_and_deduplication>,
            <https://example.test/enron-emails#eml_messages> ;
        rc:claimText "Duplicate message_id, duplicate subject_clean, duplicate non-empty bodies, duplicate non-empty body_top, and high reply_depth values all show that conversation-level analysis should not rely on one field." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_xml_attachment_count_mismatch> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_xml_attachment_count_mismatch>,
            <https://example.test/enron-emails#xml_attachments>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:claimText "XML message has_attachments matches attachment-row presence, but attachment_count differs from aggregated xml_attachments rows for 3,128 messages." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .

    <https://example.test/enron-emails#claim_doc_id_key_and_overlap> a rc:Claim ;
        rc:claimKind rc:JoinClaim ;
        rc:claimTarget <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#eml_messages__doc_id>,
            <https://example.test/enron-emails#xml_messages>,
            <https://example.test/enron-emails#xml_messages__doc_id> ;
        rc:claimText "doc_id is non-null and unique in both message tables; XML doc_ids are a strict subset of EML doc_ids with 1,227,255 overlaps and 7,132 EML-only rows." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked ;
        rc:proposedAssertion <https://example.test/enron-emails#relationship_eml_xml_doc_id_shared_identifier> .

    <https://example.test/enron-emails#claim_sender_representation_differs> a rc:Claim ;
        rc:claimKind rc:CaveatClaim ;
        rc:claimTarget <https://example.test/enron-emails#caveat_sender_representation>,
            <https://example.test/enron-emails#eml_messages__from_email>,
            <https://example.test/enron-emails#xml_messages__from_> ;
        rc:claimText "EML from_email is sparse while XML from_ uses display-name strings; representation-specific parsing is required before cross-source sender analytics." ;
        rc:confidence rc:HighConfidence ;
        rc:observationStatus rc:Checked .
}

rcg:ontology {
    <https://example.test/enron-emails#EmailAttachmentTable> a rdfs:Class ;
        rdfs:label "email attachment table" ;
        rdfs:subClassOf rc:Table .

    <https://example.test/enron-emails#EmailMessageTable> a rdfs:Class ;
        rdfs:label "email message table" ;
        rdfs:subClassOf rc:Table .

    <https://example.test/enron-emails#AttachmentCount> a rc:ValueType ;
        rdfs:label "attachment count" ;
        rc:requiredPhysicalType rc:Integer .

    <https://example.test/enron-emails#AttachmentFileExtension> a rc:ValueType ;
        rdfs:label "attachment file extension" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#AttachmentFileName> a rc:ValueType ;
        rdfs:label "attachment file name" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#AttachmentNameListString> a rc:ValueType ;
        rdfs:label "attachment name list string" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#AttachmentTimestamp> a rc:ValueType ;
        rdfs:label "attachment timestamp" ;
        rc:requiredPhysicalType rc:TimestampTZ .

    <https://example.test/enron-emails#CleanEmailSubject> a rc:ValueType ;
        rdfs:label "cleaned email subject" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#Custodian> a rc:ValueType ;
        rdfs:label "custodian" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#DocumentId> a rc:ValueType ;
        rdfs:label "Enron document id" ;
        rc:identifierNamespace "enron-emails/doc_id" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#EmailAddress> a rc:ValueType ;
        rdfs:label "email address" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#EmailAddressListString> a rc:ValueType ;
        rdfs:label "email address list string" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#EmailBodyText> a rc:ValueType ;
        rdfs:label "email body text" ;
        rc:requiredPhysicalType rc:Text .

    <https://example.test/enron-emails#EmailSubject> a rc:ValueType ;
        rdfs:label "email subject" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#ExtractedTextPath> a rc:ValueType ;
        rdfs:label "extracted text path" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#FileSizeBytes> a rc:ValueType ;
        rdfs:label "file size in bytes" ;
        rc:acceptablePhysicalType rc:Integer,
            rc:UBigInt .

    <https://example.test/enron-emails#HasAttachmentFlag> a rc:ValueType ;
        rdfs:label "has attachment flag" ;
        rc:requiredPhysicalType rc:Boolean .

    <https://example.test/enron-emails#MailboxFolder> a rc:ValueType ;
        rdfs:label "mailbox folder" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#MailboxLocationUri> a rc:ValueType ;
        rdfs:label "mailbox location URI" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#MessageForwardFlag> a rc:ValueType ;
        rdfs:label "message forward flag" ;
        rc:requiredPhysicalType rc:Boolean .

    <https://example.test/enron-emails#MessageId> a rc:ValueType ;
        rdfs:label "RFC-style message id" ;
        rc:identifierNamespace "email/message-id" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#MessageReplyFlag> a rc:ValueType ;
        rdfs:label "message reply flag" ;
        rc:requiredPhysicalType rc:Boolean .

    <https://example.test/enron-emails#MessageTimestamp> a rc:ValueType ;
        rdfs:label "message timestamp" ;
        rc:requiredPhysicalType rc:TimestampTZ .

    <https://example.test/enron-emails#MimeType> a rc:ValueType ;
        rdfs:label "MIME type" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#NativeContentHash> a rc:ValueType ;
        rdfs:label "native content hash" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#NativeObjectPath> a rc:ValueType ;
        rdfs:label "native object path" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#PersonDisplayName> a rc:ValueType ;
        rdfs:label "person display name" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#RecipientListString> a rc:ValueType ;
        rdfs:label "recipient list string" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#RegexEmailAddressExtraction> a rdfs:Resource ;
        rdfs:label "regex email address extraction" ;
        rdfs:comment "A lightweight parser strategy for extracting address-like tokens from sender and recipient string fields." .

    <https://example.test/enron-emails#ReplyDepth> a rc:ValueType ;
        rdfs:label "reply depth" ;
        rc:requiredPhysicalType rc:Integer .

    <https://example.test/enron-emails#SenderDisplayString> a rc:ValueType ;
        rdfs:label "sender display string" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#SenderRawString> a rc:ValueType ;
        rdfs:label "raw sender string" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#SourceDocumentCode> a rc:ValueType ;
        rdfs:label "source document code" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#SourceFileName> a rc:ValueType ;
        rdfs:label "source file name" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#SourceLoadIdentifier> a rc:ValueType ;
        rdfs:label "source load identifier" ;
        rc:requiredPhysicalType rc:Varchar .

    <https://example.test/enron-emails#TopLevelEmailBodyText> a rc:ValueType ;
        rdfs:label "top-level email body text" ;
        rc:requiredPhysicalType rc:Text .

    <https://example.test/enron-emails#SafeEnronEraWindow> a rdfs:Resource ;
        rdfs:label "safe Enron-era date window" ;
        rdfs:comment "The working case-study date filter from 1997-01-01 inclusive through 2005-01-01 exclusive." .

    <https://example.test/enron-emails#ExtractTopLevelBodyText> a rdfs:Resource ;
        rdfs:label "extract top-level body text" ;
        rdfs:comment "A project-local transformation function representing derivation of body_top from body by removing or suppressing quoted-history text." .
}

