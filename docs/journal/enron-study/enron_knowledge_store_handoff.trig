rcg:patterns {
    <https://example.test/enron-emails#pattern_analysis_hygiene_before_modeling> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:evidence <https://richcanopy.org/doxabase/generated/evidence/89e94a4c-0f9b-44fb-8ae8-97ae97423a1c> ;
        rc:mapImplication <https://example.test/enron-emails#caveat_attachment_extensions_case_empty>,
            <https://example.test/enron-emails#caveat_body_top_transformation>,
            <https://example.test/enron-emails#caveat_date_plausibility>,
            <https://example.test/enron-emails#caveat_empty_strings>,
            <https://example.test/enron-emails#caveat_sender_representation>,
            <https://example.test/enron-emails#caveat_xml_attachment_count_mismatch> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_attachments>,
            <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_attachments>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:patternText "Before modeling recipients, time series, attachment types, sender networks, or message text, normalize empty strings, date outliers, extension case, sender representations, and body/body_top selection." ;
        rc:rationale "The profile found empty-string missingness, severe XML date outliers, mixed-case/blank attachment extensions, sparse EML sender emails, and a derived body_top field." ;
        rc:summary "Basic cleaning choices materially affect downstream Enron analyses." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_body_top_derived>,
            <https://example.test/enron-emails#claim_date_outliers>,
            <https://example.test/enron-emails#claim_empty_string_missingness>,
            <https://example.test/enron-emails#claim_sender_representation_differs>,
            <https://example.test/enron-emails#claim_xml_attachment_count_mismatch> ;
        rc:supportingObservation <https://example.test/enron-emails#obs_eml_attachment_extensions>,
            <https://example.test/enron-emails#obs_top_eml_folders>,
            <https://example.test/enron-emails#obs_top_eml_senders>,
            <https://example.test/enron-emails#obs_top_xml_folders>,
            <https://example.test/enron-emails#obs_top_xml_senders>,
            <https://example.test/enron-emails#obs_xml_attachment_extensions> ;
        rc:synthesizedAt "2026-07-01T10:53:20.730775+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_attachment_analysis_prefers_xml_hashes> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:mapImplication <https://example.test/enron-emails#caveat_attachment_hash_duplicates> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_attachments>,
            <https://example.test/enron-emails#xml_attachments> ;
        rc:patternText "EML and XML extension distributions are nearly parallel after normalization, but XML adds native_hash, native_path, and text_path fields needed for attachment identity and duplicate-content analysis." ;
        rc:rationale "Extension, MIME, hash-duplication, and size profiles show both shared attachment shape and XML's richer identity fields." ;
        rc:summary "Attachment analysis should use normalized extensions plus XML native hashes." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_attachment_hash_extension_deep> ;
        rc:supportingObservation <https://example.test/enron-emails#obs_eml_normalized_extensions>,
            <https://example.test/enron-emails#obs_xml_normalized_extensions> ;
        rc:synthesizedAt "2026-07-01T10:53:29.329561+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_custodian_folder_are_primary_strata> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:mapImplication <https://example.test/enron-emails#caveat_custodian_skew_and_body_coverage>,
            <https://example.test/enron-emails#caveat_folder_family_semantics> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_messages__custodian>,
            <https://example.test/enron-emails#eml_messages__folder>,
            <https://example.test/enron-emails#xml_messages__location_uri> ;
        rc:patternText "Custodian and folder/location family strongly structure row counts, text readiness, attachment rates, and date quality. They should be first-class grouping variables in exploratory summaries." ;
        rc:rationale "Grouped profiles show skewed custodians and folder families with sharply different completeness and semantics." ;
        rc:summary "Custodian and folder/location family are primary analysis strata." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_custodian_skew_requires_reporting>,
            <https://example.test/enron-emails#claim_folder_families_have_semantics> ;
        rc:supportingObservation <https://example.test/enron-emails#obs_eml_folder_family_counts>,
            <https://example.test/enron-emails#obs_top_message_custodian_counts>,
            <https://example.test/enron-emails#obs_xml_location_family_counts> ;
        rc:synthesizedAt "2026-07-01T12:39:04.497911+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_doc_id_first_join_strategy> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:evidence <https://richcanopy.org/doxabase/generated/evidence/8ca9fa6f-73ca-4190-af00-d896ec8652ae> ;
        rc:mapImplication <https://example.test/enron-emails#caveat_message_id_not_key>,
            <https://example.test/enron-emails#caveat_source_codes_blank>,
            <https://example.test/enron-emails#relationship_eml_attachment_parent_doc_id_to_eml_doc_id>,
            <https://example.test/enron-emails#relationship_xml_attachment_parent_doc_id_to_xml_doc_id> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:InvariantPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_attachments__parent_doc_id>,
            <https://example.test/enron-emails#eml_messages__doc_id>,
            <https://example.test/enron-emails#xml_attachments__parent_doc_id>,
            <https://example.test/enron-emails#xml_messages__doc_id> ;
        rc:patternText "Use doc_id for message identity and parent_doc_id-to-doc_id for attachment joins. Avoid using EML message_id, x_sdoc, or x_zlid as universal keys." ;
        rc:rationale "doc_id is unique and complete in both message tables; attachment parent_doc_id coverage is complete; EML message_id has duplicate groups and x_sdoc/x_zlid have large blank populations." ;
        rc:summary "doc_id-first joins are the reliable starting point." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_attachment_foreign_keys>,
            <https://example.test/enron-emails#claim_doc_id_key_and_overlap> ;
        rc:synthesizedAt "2026-07-01T10:53:20.712193+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_eml_only_subset_is_special_case> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:mapImplication <https://example.test/enron-emails#caveat_eml_only_blank_source_subset> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:patternText "The EML-only rows are not an arbitrary scatter: they all have blank source_file and folder, come from 31 custodians, and preserve only a small attachment footprint." ;
        rc:rationale "Anti-join profiling found uniform blank source fields and bounded dates for the EML-only subset." ;
        rc:summary "The EML-only message gap is a coherent special subset." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_eml_only_blank_source_subset_deep> ;
        rc:synthesizedAt "2026-07-01T10:53:29.297190+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_global_dedup_preserve_provenance> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:mapImplication <https://example.test/enron-emails#caveat_attachment_heavy_tail>,
            <https://example.test/enron-emails#caveat_dedup_clusters_cross_context> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_attachments> ;
        rc:patternText "Duplicate clusters cross custodians and folders often enough that local slice-by-slice deduplication can bias results. A safer path is corpus-wide clustering with custodian/folder provenance retained." ;
        rc:rationale "message_id, body hash, and XML native_hash duplicate groups all cross contextual boundaries." ;
        rc:summary "Deduplication should be global while preserving provenance." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_attachment_heavy_tail_requires_robust_summaries>,
            <https://example.test/enron-emails#claim_duplicates_cross_contexts> ;
        rc:synthesizedAt "2026-07-01T12:39:04.512619+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_message_like_views_support_nlp_and_networks> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:evidence <https://richcanopy.org/doxabase/generated/evidence/57637553-8f9e-4eb2-afd2-d8021b27eedd> ;
        rc:mapImplication <https://example.test/enron-emails#caveat_message_like_population> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:patternText "Excluding calendar/contact/meeting families after the plausible-date filter creates a more appropriate denominator for ordinary message NLP and network analysis than the raw message tables." ;
        rc:rationale "Candidate population counts show materially different row counts after folder-family exclusions and body/body_top requirements." ;
        rc:summary "Message-like views support NLP and communication-network workflows." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_message_like_population_network_pass> ;
        rc:supportingObservation <https://example.test/enron-emails#obs_message_like_population_counts_network_pass> ;
        rc:synthesizedAt "2026-07-01T13:53:25.102940+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_named_analysis_views_reduce_ambiguity> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:evidence <https://richcanopy.org/doxabase/generated/evidence/fcd651c5-1f2d-46a7-89a8-e664520ed0a8> ;
        rc:mapImplication <https://example.test/enron-emails#caveat_analysis_population_views> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:patternText "Counts, models, and networks over this corpus should cite a named logical population, such as plausible-date EML, XML overlap, EML-only blank-source subset, body-text rows, or regex-sender rows." ;
        rc:rationale "Different reasonable filters change row counts materially; preserving view names prevents silent denominator drift." ;
        rc:summary "Named analysis views reduce ambiguity in downstream work." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_analysis_views_define_populations> ;
        rc:supportingObservation <https://example.test/enron-emails#obs_recommended_analysis_view_counts> ;
