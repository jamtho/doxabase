    <https://example.test/enron-emails#pattern_parallel_message_representations> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:evidence <https://richcanopy.org/doxabase/generated/evidence/b8a81688-cc74-46bc-b950-531d481bfafa> ;
        rc:mapImplication <https://example.test/enron-emails#caveat_parallel_representations>,
            <https://example.test/enron-emails#relationship_eml_xml_doc_id_shared_identifier> ;
        rc:observationStatus rc:Checked ;
        rc:patternStability rc:RepeatedPattern ;
        rc:patternTarget <https://example.test/enron-emails#eml_messages>,
            <https://example.test/enron-emails#xml_messages> ;
        rc:patternText "EML is the broader message representation, XML is a strict doc_id subset with richer native-path/hash metadata and display-name sender fields. Analyses should choose the representation by task instead of assuming row-for-row interchangeability." ;
        rc:rationale "Row counts, doc_id overlap checks, schema differences, and sender/folder distributions all show that the tables describe related but not identical message surfaces." ;
        rc:summary "EML and XML message tables are parallel representations with a subset relationship." ;
        rc:supportingClaim <https://example.test/enron-emails#claim_doc_id_key_and_overlap>,
            <https://example.test/enron-emails#claim_sender_representation_differs> ;
        rc:synthesizedAt "2026-07-01T10:53:20.693553+00:00"^^xsd:dateTime .

    <https://example.test/enron-emails#pattern_query_cookbook_as_onramp> a rc:Pattern ;
        rc:confidence rc:HighConfidence ;
        rc:evidence <https://richcanopy.org/doxabase/generated/evidence/00e0aa2b-256f-4edc-bac2-ad4b1a381bb1> ;
