        rdfs:comment "Observed large_string column in eml_messages. Full scan found 0 nulls and 1825 distinct values." ;
        rc:columnName "folder" ;
        rc:hasKnownCaveat <https://example.test/enron-emails#caveat_folder_family_semantics>,
            <https://example.test/enron-emails#caveat_monthly_calendar_spike> ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:MailboxFolder> .

    <https://example.test/enron-emails#xml_attachments__doc_id> a rc:Column ;
        rdfs:label "XML attachments doc_id" ;
        rdfs:comment "Observed large_string column in xml_attachments. Full scan found 0 nulls and 493384 distinct values." ;
        rc:columnName "doc_id" ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:DocumentId> .

    <https://example.test/enron-emails#xml_messages__location_uri> a rc:Column ;
        rdfs:label "XML messages location_uri" ;
        rdfs:comment "Observed large_string column in xml_messages. Full scan found 0 nulls and 3695 distinct values." ;
        rc:columnName "location_uri" ;
        rc:hasKnownCaveat <https://example.test/enron-emails#caveat_folder_family_semantics>,
            <https://example.test/enron-emails#caveat_monthly_calendar_spike> ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:MailboxLocationUri> .

    <https://example.test/enron-emails#caveat_address_regex_incomplete> a rc:KnownCaveat ;
        rdfs:label "regex email extraction is incomplete" ;
        rc:caveatDescription "Regex extraction finds useful domains but misses many populated sender/recipient strings. For example, EML to_addrs is populated on 652,110 rows but regex email tokens appear in only 215,775 rows; XML to is populated on 746,550 rows with regex tokens in 311,860 rows. Some fields contain Exchange/X.500-style markers." ;
        rc:impact "Network analysis needs a parser strategy and coverage audit, not raw string grouping alone." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_analysis_population_views> a rc:KnownCaveat ;
        rdfs:label "analysis populations should be named explicitly" ;
        rc:caveatDescription "Recommended logical populations include plausible-date EML messages (1,210,548 rows), plausible-date XML messages (1,203,416 rows), EML/XML overlap (1,227,255 rows), EML-only blank-source subset (7,132 rows), body-text rows (739,872), body_top-text rows (695,225), EML regex sender rows (97,929), and XML regex sender rows (198,050)." ;
        rc:impact "Analysts should name and preserve the population definition behind every count, model, network, or NLP run." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_attachment_extensions_case_empty> a rc:KnownCaveat ;
        rdfs:label "attachment extensions are case-sensitive and sometimes empty" ;
        rc:caveatDescription "Attachment extensions appear in mixed case and include empty strings. For example, EML has both doc/DOC and pdf/PDF buckets, and XML has 25,413 empty file_extension rows." ;
        rc:impact "Normalize extension case and handle blank extensions before file-type analysis." ;
        rc:severity rc:Minor .

    <https://example.test/enron-emails#caveat_attachment_hash_duplicates> a rc:KnownCaveat ;
        rdfs:label "XML attachment hashes expose many duplicate-content rows" ;
        rc:caveatDescription "XML attachment native_hash has 67,685 duplicate groups covering 417,668 rows. The largest observed native_hash appears 1,063 times." ;
        rc:impact "Use XML native_hash for duplicate-content analysis, but expect many repeated attachments across custodians and messages." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_communication_domain_coverage> a rc:KnownCaveat ;
        rdfs:label "domain-level communication networks are coverage-limited" ;
        rc:caveatDescription "Regex domain extraction yields useful domain-level matrices, but many rows have no regex sender or recipient domain. EML has 1,001,806 rows in the none->none sender/recipient class bucket; XML has 895,661. XML has stronger regex sender coverage than EML because XML from_ often embeds Enron addresses." ;
        rc:impact "Domain network analysis should report extractability and treat none-class rows as missing parser coverage, not absence of communication." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_custodian_skew_and_body_coverage> a rc:KnownCaveat ;
        rdfs:label "custodian slices are present in both representations but highly skewed" ;
        rc:caveatDescription "All 151 custodians appear in both EML and XML message tables, but row counts are highly skewed. The largest custodian slice is kean-s with 225,665 EML rows and 225,633 XML rows. Body-text coverage also varies strongly by custodian." ;
        rc:impact "Custodian-level analyses should report per-custodian support and avoid treating the corpus as evenly sampled." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_dedup_clusters_cross_context> a rc:KnownCaveat ;
        rdfs:label "duplicate clusters cross custodians and folders" ;
        rc:caveatDescription "Duplicate EML message_id groups cross custodians in 7,490 groups and folders in 6,823 groups. Duplicate non-empty body groups cross custodians in 9,917 groups and folders in 121,335 groups. XML attachment native_hash duplicate groups cross custodians in 11,771 groups." ;
        rc:impact "Deduplication should be corpus-wide and should preserve custodian/folder provenance instead of deduplicating inside isolated slices only." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_eml_only_blank_source_subset> a rc:KnownCaveat ;
        rdfs:label "EML-only rows are a blank-source subset" ;
        rc:caveatDescription "The 7,132 EML message rows absent from XML all have blank folder and blank source_file. They span 31 custodians, have dates from 2000-03-29 through 2002-01-07, and include 17 messages flagged with one attachment each." ;
        rc:impact "Treat EML-only rows as a special coverage subset before comparing EML and XML analyses." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_folder_family_semantics> a rc:KnownCaveat ;
        rdfs:label "folder families mix analysis semantics" ;
        rc:caveatDescription "Top folder/location families such as all documents, calendar, discussion threads, sent, contacts, and blank have very different body coverage, attachment rates, custodian coverage, and date-outlier profiles." ;
        rc:impact "Folder/location analyses should normalize folder families and treat calendar/contact/system-like folders separately from ordinary messages." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_message_id_not_key> a rc:KnownCaveat ;
        rdfs:label "EML message_id is not unique" ;
        rc:caveatDescription "EML doc_id is unique and non-null, but message_id has 25,462 duplicate groups, 64,332 rows in duplicate groups, and up to 73 rows sharing one message_id." ;
        rc:impact "Use doc_id as the row key; use message_id only for conversation or duplicate analysis." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_parallel_representations> a rc:KnownCaveat ;
        rdfs:label "EML and XML representations are not identical" ;
        rc:caveatDescription "XML messages are a strict subset of EML by doc_id in the observed files. All 1,227,255 XML doc_ids appear in EML, while 7,132 EML rows, all with blank folder, do not appear in XML." ;
        rc:impact "Do not treat EML/XML row counts as interchangeable without choosing a representation." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_text_surface_readiness> a rc:KnownCaveat ;
        rdfs:label "body and body_top have different NLP readiness tradeoffs" ;
        rc:caveatDescription "EML body is blank in 494,515 rows and body_top is blank in 539,162 rows. body_top removes the observed original-message marker entirely, but it is shorter than body for 208,906 rows and may discard useful context." ;
        rc:impact "NLP pipelines should choose body versus body_top by task and preserve the choice in analysis metadata." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#eml_attachments__parent_doc_id> a rc:Column ;
        rdfs:label "EML attachments parent_doc_id" ;
        rdfs:comment "Observed large_string column in eml_attachments. Full scan found 0 nulls and 245261 distinct values." ;
        rc:columnName "parent_doc_id" ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:DocumentId> .

    <https://example.test/enron-emails#xml_attachments__parent_doc_id> a rc:Column ;
        rdfs:label "XML attachments parent_doc_id" ;
        rdfs:comment "Observed large_string column in xml_attachments. Full scan found 0 nulls and 245250 distinct values." ;
        rc:columnName "parent_doc_id" ;
        rc:nullable false ;
        rc:physicalType rc:Varchar ;
        rc:valueType <enron:DocumentId> .

    <https://example.test/enron-emails#caveat_body_top_transformation> a rc:KnownCaveat ;
        rdfs:label "body_top is a derived text surface" ;
        rc:caveatDescription "EML body_top equals body for 1,025,481 rows and is shorter than body for 208,906 rows. It is useful for top-level-message analysis but should be treated as derived from body." ;
        rc:impact "Choose body or body_top deliberately for NLP and quote/context retrieval tasks." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_message_like_population> a rc:KnownCaveat ;
        rdfs:label "message-like population excludes calendar/contact/meeting families" ;
        rc:caveatDescription "A practical message-like population excludes calendar, contacts, and meetings after date filtering. That gives 980,561 EML rows, 714,325 EML rows with body text, 670,649 EML rows with body_top text, and 973,356 XML rows." ;
        rc:impact "NLP or network analyses over ordinary messages should cite whether these families were excluded." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_source_codes_blank> a rc:KnownCaveat ;
        rdfs:label "EML source codes are blank for many rows" ;
        rc:caveatDescription "EML x_sdoc and x_zlid each have 114,682 blank values, creating one large duplicate group. They are useful source metadata where populated but not universal keys." ;
        rc:impact "Use doc_id for identity and treat x_sdoc/x_zlid as optional source metadata." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_threading_and_deduplication> a rc:KnownCaveat ;
        rdfs:label "threading and deduplication need multi-signal logic" ;
        rc:caveatDescription "EML has 25,462 duplicate message_id groups, 121,584 duplicate non-empty subject_clean groups, 128,273 duplicate non-empty body groups, and 117,996 duplicate non-empty body_top groups. reply_depth ranges up to 56." ;
        rc:impact "Conversation or deduplication work should combine doc_id, message_id, subject_clean, reply_depth, folders, and text hashes." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_xml_attachment_count_mismatch> a rc:KnownCaveat ;
        rdfs:label "XML attachment_count sometimes disagrees with attachment rows" ;
        rc:caveatDescription "XML has_attachments matches attachment-row presence, but attachment_count disagrees with counted xml_attachments rows for 3,128 messages; the maximum absolute delta is 109." ;
        rc:impact "For exact XML attachment counts, aggregate xml_attachments by parent_doc_id instead of trusting attachment_count alone." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_attachment_heavy_tail> a rc:KnownCaveat ;
        rdfs:label "attachment counts have a heavy tail" ;
        rc:caveatDescription "Both EML and XML attachment-row counts reach 260 attachments for one message. The p99 is 4 for EML and 5 for XML, p999 is 33 for both, and 4,525 messages have 10 or more attachments." ;
        rc:impact "Attachment analyses should use robust summaries and inspect high-attachment messages separately." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_date_plausibility> a rc:KnownCaveat ;
        rdfs:label "message dates require plausibility filters" ;
        rc:caveatDescription "Message date fields contain outliers outside the usual Enron-era analysis window. EML has 23,463 rows before 1997, 115 rows after 2004, and 261 null dates; XML has 23,492 rows before 1997 and 347 rows after 2004, with extreme parsed years from 1316 to 9719." ;
        rc:impact "Time-series analysis should apply an explicit date window or outlier policy." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_monthly_calendar_spike> a rc:KnownCaveat ;
        rdfs:label "monthly volume has calendar-driven spikes" ;
        rc:caveatDescription "The largest plausible-date month is 2002-11 with 134,027 EML rows and 134,027 XML rows, but the EML folder-family/month profile attributes 126,208 of those EML rows to calendar. Naive monthly message-volume plots will overstate ordinary communications in that month." ;
        rc:impact "Monthly time-series analysis should stratify by folder/location family and consider message-like exclusions." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#caveat_sender_representation> a rc:KnownCaveat ;
        rdfs:label "sender representation differs between EML and XML" ;
        rc:caveatDescription "EML from_email is populated for only 98,103 of 1,234,387 rows, while XML from_ uses display-name style strings and is populated for 972,498 of 1,227,255 rows." ;
        rc:impact "Sender analytics need representation-specific parsing and should not simply join EML from_email to XML from_." ;
        rc:severity rc:Moderate .

    <https://example.test/enron-emails#eml_messages__doc_id> a rc:Column ;
        rdfs:label "EML messages doc_id" ;
