@prefix rc:      <https://richcanopy.org/ns/rc#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<https://richcanopy.org/ns/rc>
    a owl:Ontology ;
    dcterms:title "Rich Canopy base ontology" ;
    dcterms:description "A small, extensible vocabulary for describing data assets, information models, observations, evidence, and caveats in Rich Canopy projects." ;
    owl:versionInfo "0.1.0-draft" .

# -----------------------------------------------------------------------------
# Data assets
# -----------------------------------------------------------------------------

rc:DataAsset a rdfs:Class ;
    rdfs:comment "Any data-bearing asset that a project may describe, map, profile, or use as evidence." .

rc:Dataset a rdfs:Class ;
    rdfs:subClassOf rc:DataAsset ;
    rdfs:comment "A logical collection of data. A dataset may be a database, data lake, file collection, table-like resource, API-backed source, or another project-defined asset." .

rc:Database a rdfs:Class ;
    rdfs:subClassOf rc:DataAsset ;
    rdfs:comment "A database, warehouse, catalog, cluster, or similar container of data resources." .

rc:DataFile a rdfs:Class ;
    rdfs:subClassOf rc:DataAsset ;
    rdfs:comment "A single physical or addressable data file." .

rc:Table a rdfs:Class ;
    rdfs:subClassOf rc:DataAsset ;
    rdfs:comment "A logical tabular structure with rows and columns. SQL tables, views, dataframes, query results, CSV files, and Parquet files may all be tables when appropriate." .

rc:DataFrame a rdfs:Class ;
    rdfs:subClassOf rc:Table ;
    rdfs:comment "An in-memory or dataframe-library-backed table." .

rc:Column a rdfs:Class ;
    rdfs:comment "A column in a logical tabular structure." .

rc:ColumnGroup a rdfs:Class ;
    rdfs:comment "A named group of columns that together carry a composite meaning." .

rc:hasColumn a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:Column ;
    rdfs:comment "Links a data asset or table-like resource to a column." .

rc:hasColumnGroup a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:ColumnGroup ;
    rdfs:comment "Links a data asset or table-like resource to a composite column group." .

rc:columnName a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range xsd:string ;
    rdfs:comment "The physical or source-level column name." .

rc:memberOf a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range rc:ColumnGroup ;
    rdfs:comment "Links a column to a column group it participates in." .

rc:groupMember a rdf:Property ;
    rdfs:domain rc:ColumnGroup ;
    rdfs:range rc:Column ;
    rdfs:comment "A column that participates in a column group." .

rc:groupValueType a rdf:Property ;
    rdfs:domain rc:ColumnGroup ;
    rdfs:range rc:ValueType ;
    rdfs:comment "The composite value type carried by a column group." .

rc:memberRole a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:comment "The role a column plays within a column group." .

rc:physicalType a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range rc:PhysicalType ;
    rdfs:comment "The storage-level or source-level type of values in a column." .

rc:valueType a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range rc:ValueType ;
    rdfs:comment "The project/domain meaningful type of values in a column." .

rc:nullable a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether null values are expected or permitted." .

rc:rowSemantics a rdf:Property ;
    rdfs:label "row semantics" ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:RowSemanticsType ;
    rdfs:comment "What each row in a table-like asset represents." .

rc:entityKey a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:Column ;
    rdfs:comment "A column that identifies the recurring entity described by rows in a table-like asset." .

rc:snapshotTimestamp a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:Column ;
    rdfs:comment "A column that identifies the point in time for each row or snapshot." .

rc:schemaStability a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:SchemaStabilityLevel ;
    rdfs:comment "How stable the source schema is expected to be." .

rc:rowCountSnapshot a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range xsd:integer ;
    rdfs:comment "Observed or asserted row count at a point in time. This is a snapshot, not a standing guarantee." .

rc:pathTemplate a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:comment "A path or URI template for locating files, partitions, tables, or other data resources." .

# -----------------------------------------------------------------------------
# Physical and value types
# -----------------------------------------------------------------------------

rc:PhysicalType a rdfs:Class ;
    rdfs:comment "A storage-level data type." .

rc:ValueType a rdfs:Class ;
    rdfs:comment "A domain-meaningful value type. Client projects are expected to define their own value types freely." .

rc:ValueRange a rdfs:Class ;
    rdfs:comment "A range constraint for values." .

rc:AllowedValues a rdfs:Class ;
    rdfs:comment "A declared set of permitted values. This is distinct from observed values found during profiling." .

rc:EmbeddedStructure a rdfs:Class ;
    rdfs:comment "A description of structured content embedded inside a scalar value, such as JSON encoded in a string column." .

rc:DataEncodingFormat a rdfs:Class ;
    rdfs:comment "An encoding format for embedded structured data." .

rc:requiredPhysicalType a rdf:Property ;
    rdfs:domain rc:ValueType ;
    rdfs:range rc:PhysicalType ;
    rdfs:comment "The physical type a value type must use." .

rc:acceptablePhysicalType a rdf:Property ;
    rdfs:domain rc:ValueType ;
    rdfs:range rc:PhysicalType ;
    rdfs:comment "A physical type acceptable for a value type when multiple storage representations are valid." .

rc:valueRange a rdf:Property ;
    rdfs:domain rc:ValueType ;
    rdfs:range rc:ValueRange ;
    rdfs:comment "Links a value type to a valid value range." .

rc:minInclusive a rdf:Property ;
    rdfs:domain rc:ValueRange ;
    rdfs:comment "Inclusive lower bound for a value range." .

rc:maxInclusive a rdf:Property ;
    rdfs:domain rc:ValueRange ;
    rdfs:comment "Inclusive upper bound for a value range." .

rc:minExclusive a rdf:Property ;
    rdfs:domain rc:ValueRange ;
    rdfs:comment "Exclusive lower bound for a value range." .

rc:maxExclusive a rdf:Property ;
    rdfs:domain rc:ValueRange ;
    rdfs:comment "Exclusive upper bound for a value range." .

rc:unit a rdf:Property ;
    rdfs:domain rc:ValueType ;
    rdfs:range xsd:string ;
    rdfs:comment "A unit of measure for values of this type." .

rc:identifierNamespace a rdf:Property ;
    rdfs:domain rc:ValueType ;
    rdfs:range xsd:string ;
    rdfs:comment "A namespace or population identifier for comparable entity identifiers." .

rc:hasAllowedValues a rdf:Property ;
    rdfs:domain rc:ValueType ;
    rdfs:range rc:AllowedValues ;
    rdfs:comment "Links a value type to its declared allowed values." .

rc:allowedValue a rdf:Property ;
    rdfs:domain rc:AllowedValues ;
    rdfs:comment "One declared permitted value." .

rc:embeddedStructure a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range rc:EmbeddedStructure ;
    rdfs:comment "Declares that a column contains structured content encoded inside a scalar value." .

rc:embeddedFormat a rdf:Property ;
    rdfs:domain rc:EmbeddedStructure ;
    rdfs:range rc:DataEncodingFormat ;
    rdfs:comment "The encoding format of embedded structured content." .

rc:embeddedElementType a rdf:Property ;
    rdfs:domain rc:EmbeddedStructure ;
    rdfs:range xsd:string ;
    rdfs:comment "A compact description of the inner element or schema shape." .

rc:caseConvention a rdf:Property ;
    rdfs:domain rc:Column ;
    rdfs:range rc:CaseConvention ;
    rdfs:comment "Casing convention for string values in a column." .

rc:narrowerThan a rdf:Property ;
    rdfs:domain rc:PhysicalType ;
    rdfs:range rc:PhysicalType ;
    rdfs:comment "This physical type can safely widen to the target physical type." .

rc:Boolean     a rc:PhysicalType ; rdfs:label "BOOLEAN" .
rc:Integer     a rc:PhysicalType ; rdfs:label "INTEGER" .
rc:BigInt      a rc:PhysicalType ; rdfs:label "BIGINT" .
rc:UBigInt     a rc:PhysicalType ; rdfs:label "UBIGINT" .
rc:Float       a rc:PhysicalType ; rdfs:label "FLOAT" .
rc:Double      a rc:PhysicalType ; rdfs:label "DOUBLE" .
rc:Decimal     a rc:PhysicalType ; rdfs:label "DECIMAL" .
rc:Varchar     a rc:PhysicalType ; rdfs:label "VARCHAR" .
rc:Text        a rc:PhysicalType ; rdfs:label "TEXT" .
rc:Date        a rc:PhysicalType ; rdfs:label "DATE" .
rc:Timestamp   a rc:PhysicalType ; rdfs:label "TIMESTAMP" .
rc:TimestampTZ a rc:PhysicalType ; rdfs:label "TIMESTAMP WITH TIME ZONE" .
rc:Blob        a rc:PhysicalType ; rdfs:label "BLOB" .
rc:JSONValue   a rc:PhysicalType ; rdfs:label "JSON" .
rc:Struct      a rc:PhysicalType ; rdfs:label "STRUCT" .
rc:IntegerList a rc:PhysicalType ; rdfs:label "INTEGER[]" .
rc:DoubleList  a rc:PhysicalType ; rdfs:label "DOUBLE[]" .
rc:VarcharList a rc:PhysicalType ; rdfs:label "VARCHAR[]" .

rc:Integer rc:narrowerThan rc:BigInt .
rc:BigInt rc:narrowerThan rc:Double .
rc:Float rc:narrowerThan rc:Double .

rc:CaseConvention a rdfs:Class ;
    rdfs:comment "Casing applied to string values." .

rc:UpperCase a rc:CaseConvention ; rdfs:label "uppercase" .
rc:LowerCase a rc:CaseConvention ; rdfs:label "lowercase" .
rc:MixedCase a rc:CaseConvention ; rdfs:label "mixed-case" .

rc:JSONEncoding a rc:DataEncodingFormat ; rdfs:label "json" .
rc:CSVEncoding a rc:DataEncodingFormat ; rdfs:label "csv" .

# -----------------------------------------------------------------------------
# Row and schema interpretation
# -----------------------------------------------------------------------------

rc:RowSemanticsType a rdfs:Class ;
    rdfs:comment "The semantic meaning of a single row." .

rc:EventRow a rc:RowSemanticsType ;
    rdfs:label "event row" ;
    rdfs:comment "Each row is an independent event or observation." .

rc:SnapshotRow a rc:RowSemanticsType ;
    rdfs:label "snapshot row" ;
    rdfs:comment "Each row is a point-in-time observation of a recurring entity." .

rc:AggregateRow a rc:RowSemanticsType ;
    rdfs:label "aggregate row" ;
    rdfs:comment "Each row summarizes a group of source rows." .

rc:DimensionRow a rc:RowSemanticsType ;
    rdfs:label "dimension row" ;
    rdfs:comment "Each row describes a relatively stable entity or dimension member." .

rc:SchemaStabilityLevel a rdfs:Class ;
    rdfs:comment "Expected stability of an asset's schema." .

rc:FixedSchema a rc:SchemaStabilityLevel ;
    rdfs:comment "The schema is declared and expected to remain fixed." .

rc:InferredSchema a rc:SchemaStabilityLevel ;
    rdfs:comment "The schema is inferred from observed data and may vary with content." .

rc:VariableSchema a rc:SchemaStabilityLevel ;
    rdfs:comment "The schema is expected to change as the upstream source evolves." .

# -----------------------------------------------------------------------------
# Relationships, derivations, and constraints
# -----------------------------------------------------------------------------

rc:Relationship a rdfs:Class ;
    rdfs:comment "A relationship between data assets, columns, values, or project entities." .

rc:ForeignKey a rdfs:Class ;
    rdfs:subClassOf rc:Relationship ;
    rdfs:comment "A referential relationship from one column to another." .

rc:SharedIdentifier a rdfs:Class ;
    rdfs:subClassOf rc:Relationship ;
    rdfs:comment "A declaration that multiple columns carry identifiers for the same logical entity or join population. This is not owl:sameAs." .

rc:Derivation a rdfs:Class ;
    rdfs:subClassOf rc:Relationship ;
    rdfs:comment "A declaration that one column, table, dataset, or value is derived from others." .

rc:Aggregation a rdfs:Class ;
    rdfs:subClassOf rc:Relationship ;
    rdfs:comment "A declaration that a target asset or column is derived by grouping and aggregating a source." .

rc:AggregatedColumn a rdfs:Class ;
    rdfs:comment "A per-column mapping inside an aggregation relationship." .

rc:Constraint a rdfs:Class ;
    rdfs:comment "A project-level expectation, invariant, or rule that may be checked or cited." .

rc:ComputationalProfile a rdfs:Class ;
    rdfs:comment "A coarse description of the cost or method needed to verify a constraint or claim." .

rc:DerivationProperty a rdfs:Class ;
    rdfs:comment "A property of a derivation, such as deterministic, invertible, or lossy." .

rc:foreignKeyFrom a rdf:Property ;
    rdfs:domain rc:ForeignKey ;
    rdfs:range rc:Column ;
    rdfs:comment "The referencing column in a foreign-key relationship." .

rc:foreignKeyTo a rdf:Property ;
    rdfs:domain rc:ForeignKey ;
    rdfs:range rc:Column ;
    rdfs:comment "The referenced column in a foreign-key relationship." .

rc:referentialIntegrity a rdf:Property ;
    rdfs:domain rc:ForeignKey ;
    rdfs:range rc:ReferentialIntegrityLevel ;
    rdfs:comment "Expected referential-integrity level." .

rc:declared a rdf:Property ;
    rdfs:domain rc:ForeignKey ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the relationship is declared and enforced in the upstream system." .

rc:ReferentialIntegrityLevel a rdfs:Class ;
    rdfs:comment "Expected integrity level for referential relationships." .

rc:StrictIntegrity a rc:ReferentialIntegrityLevel ;
    rdfs:comment "Every source value is expected to exist in the target." .

rc:EventualIntegrity a rc:ReferentialIntegrityLevel ;
    rdfs:comment "Source values may be temporarily missing but are expected to resolve." .

rc:PartialIntegrity a rc:ReferentialIntegrityLevel ;
    rdfs:comment "Some source values may never resolve in the target." .

rc:identifyingColumn a rdf:Property ;
    rdfs:domain rc:SharedIdentifier ;
    rdfs:range rc:Column ;
    rdfs:comment "A column that participates in a shared-identifier relationship." .

rc:sourceDataset a rdf:Property ;
    rdfs:range rc:DataAsset ;
    rdfs:comment "The source dataset or data asset in a relationship." .

rc:targetDataset a rdf:Property ;
    rdfs:range rc:DataAsset ;
    rdfs:comment "The target dataset or data asset in a relationship." .

rc:sourceColumn a rdf:Property ;
    rdfs:range rc:Column ;
    rdfs:comment "A source column used by a relationship, derivation, or aggregation." .

rc:targetColumn a rdf:Property ;
    rdfs:range rc:Column ;
    rdfs:comment "A target column produced by a relationship, derivation, or aggregation." .

rc:derivedColumn a rdf:Property ;
    rdfs:domain rc:Derivation ;
    rdfs:range rc:Column ;
    rdfs:comment "A column produced by a derivation." .

rc:derivationFunction a rdf:Property ;
    rdfs:domain rc:Derivation ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "A URI identifying the derivation function." .

rc:hasDerivationProperty a rdf:Property ;
    rdfs:domain rc:Derivation ;
    rdfs:range rc:DerivationProperty ;
    rdfs:comment "Links a derivation to one of its declared properties." .

rc:groupByColumn a rdf:Property ;
    rdfs:domain rc:Aggregation ;
    rdfs:range rc:Column ;
    rdfs:comment "A source column used to group rows for an aggregation." .

rc:hasAggregatedColumn a rdf:Property ;
    rdfs:domain rc:Aggregation ;
    rdfs:range rc:AggregatedColumn ;
    rdfs:comment "Links an aggregation relationship to one target-column mapping." .

rc:aggregationSourceColumn a rdf:Property ;
    rdfs:range rc:Column ;
    rdfs:comment "A source column used as an input to an aggregation." .

rc:aggregationFunction a rdf:Property ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "A URI identifying the aggregation function." .

rc:withinGroupOrdering a rdf:Property ;
    rdfs:domain rc:AggregatedColumn ;
    rdfs:range rc:Column ;
    rdfs:comment "A column that defines ordering within groups for an order-sensitive aggregation." .

rc:computationalProfile a rdf:Property ;
    rdfs:range rc:ComputationalProfile ;
    rdfs:comment "The expected cost or method needed to verify a constraint or claim." .

rc:companionOf a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:DataAsset ;
    rdfs:comment "Links data assets that are co-maintained or intended to be consumed together." .

rc:SchemaCheckOnly a rc:ComputationalProfile ;
    rdfs:comment "Checkable from schema or metadata alone." .

rc:PerValueCheck a rc:ComputationalProfile ;
    rdfs:comment "Requires checking individual values." .

rc:FullScanRequired a rc:ComputationalProfile ;
    rdfs:comment "Requires scanning the full column, file, table, or dataset." .

rc:SequentialScan a rc:ComputationalProfile ;
    rdfs:comment "Requires reading values in order." .

rc:ExternalService a rc:ComputationalProfile ;
    rdfs:comment "Requires calling an external service." .

rc:Deterministic a rc:DerivationProperty ;
    rdfs:comment "Same inputs always produce the same output." .

rc:Invertible a rc:DerivationProperty ;
    rdfs:comment "The derivation can be reversed." .

rc:Lossy a rc:DerivationProperty ;
    rdfs:comment "The derivation loses information." .

rc:Min a rdfs:Resource ; rdfs:label "MIN" .
rc:Max a rdfs:Resource ; rdfs:label "MAX" .
rc:Mean a rdfs:Resource ; rdfs:label "MEAN / AVG" .
rc:Sum a rdfs:Resource ; rdfs:label "SUM" .
rc:Count a rdfs:Resource ; rdfs:label "COUNT" .
rc:CountDistinct a rdfs:Resource ; rdfs:label "COUNT DISTINCT" .
rc:DistinctList a rdfs:Resource ; rdfs:label "LIST of DISTINCT values" .
rc:First a rdfs:Resource ; rdfs:label "FIRST" .
rc:Last a rdfs:Resource ; rdfs:label "LAST" .

# -----------------------------------------------------------------------------
# Physical layout and storage access
# -----------------------------------------------------------------------------

rc:PhysicalLayout a rdfs:Class ;
    rdfs:comment "How a data asset is physically arranged or stored." .

rc:FileFormat a rdfs:Class ;
    rdfs:comment "A storage or serialization format." .

rc:CompressionCodec a rdfs:Class ;
    rdfs:comment "A compression codec used by a physical layout or file set." .

rc:RowOrdering a rdfs:Class ;
    rdfs:comment "A known ordering of rows or records." .

rc:OrderingKey a rdfs:Class ;
    rdfs:comment "One key used to define a row ordering." .

rc:SortDirection a rdfs:Class ;
    rdfs:comment "Direction of a sort key." .

rc:OrderingSemanticType a rdfs:Class ;
    rdfs:comment "Why an ordering exists or how it should be interpreted." .

rc:PartitionScheme a rdfs:Class ;
    rdfs:comment "A description of how a data asset is partitioned." .

rc:CompositePartitionScheme a rdfs:Class ;
    rdfs:subClassOf rc:PartitionScheme ;
    rdfs:comment "A partition scheme with multiple partition dimensions." .

rc:PartitionLevel a rdfs:Class ;
    rdfs:comment "A single dimension in a composite partition scheme." .

rc:TemporalGranularity a rdfs:Class ;
    rdfs:comment "Granularity of a temporal partition or level." .

rc:StorageAccess a rdfs:Class ;
    rdfs:comment "A non-secret description of how to access a data asset's physical storage." .

rc:StorageProtocol a rdfs:Class ;
    rdfs:comment "A storage or access protocol such as local filesystem, S3-compatible object storage, HTTPS, or database access." .

rc:AccessMode a rdfs:Class ;
    rdfs:comment "Whether a storage access pattern is read-only, read-write, or otherwise constrained." .

rc:LayoutVerificationStatus a rdfs:Class ;
    rdfs:comment "How strongly a physical layout, partition path, storage access pattern, or dataset-level path claim has been checked." .

rc:hasPhysicalLayout a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:PhysicalLayout ;
    rdfs:comment "Links a data asset to its physical layout." .

rc:fileFormat a rdf:Property ;
    rdfs:domain rc:PhysicalLayout ;
    rdfs:range rc:FileFormat ;
    rdfs:comment "The file, table, or serialization format." .

rc:compressionCodec a rdf:Property ;
    rdfs:domain rc:PhysicalLayout ;
    rdfs:range rc:CompressionCodec ;
    rdfs:comment "The compression codec used by files in this layout." .

rc:hasRowOrdering a rdf:Property ;
    rdfs:domain rc:PhysicalLayout ;
    rdfs:range rc:RowOrdering ;
    rdfs:comment "Links a physical layout to a known row ordering." .

rc:hasOrderingKey a rdf:Property ;
    rdfs:domain rc:RowOrdering ;
    rdfs:range rc:OrderingKey ;
    rdfs:comment "Links a row ordering to one of its keys." .

rc:keyColumn a rdf:Property ;
    rdfs:domain rc:OrderingKey ;
    rdfs:range rc:Column ;
    rdfs:comment "The column used as an ordering key." .

rc:keyDirection a rdf:Property ;
    rdfs:domain rc:OrderingKey ;
    rdfs:range rc:SortDirection ;
    rdfs:comment "The direction of an ordering key." .

rc:keyPrecedence a rdf:Property ;
    rdfs:domain rc:OrderingKey ;
    rdfs:range xsd:integer ;
    rdfs:comment "The precedence of an ordering key, where 1 is primary." .

rc:orderingSemantic a rdf:Property ;
    rdfs:domain rc:OrderingKey ;
    rdfs:range rc:OrderingSemanticType ;
    rdfs:comment "Why this ordering exists." .

rc:partitionedBy a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:PartitionScheme ;
    rdfs:comment "Declares how a data asset is partitioned." .

rc:partitionColumn a rdf:Property ;
    rdfs:domain rc:PartitionScheme ;
    rdfs:range rc:Column ;
    rdfs:comment "A column whose values determine partition placement." .

rc:partitionGranularity a rdf:Property ;
    rdfs:domain rc:PartitionScheme ;
    rdfs:range rc:TemporalGranularity ;
    rdfs:comment "Temporal granularity of a partition scheme." .

rc:redundantPartitionKey a rdf:Property ;
    rdfs:domain rc:PartitionScheme ;
    rdfs:range rc:Column ;
    rdfs:comment "A data column whose value duplicates or reflects the partition key." .

rc:hasPartitionLevel a rdf:Property ;
    rdfs:domain rc:CompositePartitionScheme ;
    rdfs:range rc:PartitionLevel ;
    rdfs:comment "Links a composite partition scheme to one of its levels." .

rc:levelPrecedence a rdf:Property ;
    rdfs:domain rc:PartitionLevel ;
    rdfs:range xsd:integer ;
    rdfs:comment "Ordering of partition levels, where 1 is outermost." .

rc:levelColumn a rdf:Property ;
    rdfs:domain rc:PartitionLevel ;
    rdfs:range xsd:string ;
    rdfs:comment "The partition-key name for this level." .

rc:levelGranularity a rdf:Property ;
    rdfs:domain rc:PartitionLevel ;
    rdfs:range rc:TemporalGranularity ;
    rdfs:comment "Granularity of this partition level." .

rc:hasStorageAccess a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:StorageAccess ;
    rdfs:comment "Links a data asset to a non-secret storage access description." .

rc:storageProtocol a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range rc:StorageProtocol ;
    rdfs:comment "The protocol or storage family used to access the data." .

rc:storageRoot a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "A non-secret root URI, root path, or logical storage root for the asset." .

rc:locationKind a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "Whether the storage location names an object, directory, prefix, or connection." .

rc:endpointProfile a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "A non-secret named endpoint profile resolved by local runtime configuration outside the graph." .

rc:bucketName a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "The non-secret bucket or container name when applicable." .

rc:keyPrefix a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "The non-secret key prefix or directory prefix when applicable." .

rc:region a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "The non-secret region or locality hint when applicable." .

rc:pathStyleAccess a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether S3-compatible access requires path-style URLs." .

rc:credentialReference a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range xsd:string ;
    rdfs:comment "A non-secret reference to credential material or runtime auth configuration stored outside the graph." .

rc:accessMode a rdf:Property ;
    rdfs:domain rc:StorageAccess ;
    rdfs:range rc:AccessMode ;
    rdfs:comment "The intended access mode for this storage description." .

rc:layoutVerificationStatus a rdf:Property ;
    rdfs:range rc:LayoutVerificationStatus ;
    rdfs:comment "Verification state for physical layout, partition, storage access, or dataset-level path metadata." .

rc:layoutVerificationNote a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:comment "Short human-readable note explaining layout/path verification state, caveats, or next checks." .

rc:Parquet a rc:FileFormat ; rdfs:label "Parquet" .
rc:CSV a rc:FileFormat ; rdfs:label "CSV" .
rc:TSV a rc:FileFormat ; rdfs:label "TSV" .
rc:ORC a rc:FileFormat ; rdfs:label "ORC" .
rc:JSON a rc:FileFormat ; rdfs:label "JSON" .
rc:JSONL a rc:FileFormat ; rdfs:label "JSONL" .
rc:NDJSON a rc:FileFormat ; rdfs:label "NDJSON" .
rc:PlainText a rc:FileFormat ; rdfs:label "Plain Text" .
rc:Markdown a rc:FileFormat ; rdfs:label "Markdown" .
rc:PostgreSQLTable a rc:FileFormat ; rdfs:label "PostgreSQL Table" .
rc:SQLiteTable a rc:FileFormat ; rdfs:label "SQLite Table" .
rc:MySQLTable a rc:FileFormat ; rdfs:label "MySQL Table" .

rc:SnappyCompression a rc:CompressionCodec ; rdfs:label "snappy" .
rc:ZstdCompression a rc:CompressionCodec ; rdfs:label "zstd" .
rc:GzipCompression a rc:CompressionCodec ; rdfs:label "gzip" .
rc:Uncompressed a rc:CompressionCodec ; rdfs:label "uncompressed" .

rc:LocalFilesystemStorage a rc:StorageProtocol ; rdfs:label "local filesystem" .
rc:S3CompatibleStorage a rc:StorageProtocol ; rdfs:label "S3-compatible object storage" .
rc:HTTPSStorage a rc:StorageProtocol ; rdfs:label "HTTPS" .
rc:DatabaseStorage a rc:StorageProtocol ; rdfs:label "database connection" .

rc:ReadOnlyAccess a rc:AccessMode ; rdfs:label "read-only" .
rc:ReadWriteAccess a rc:AccessMode ; rdfs:label "read-write" .

rc:UnverifiedLayout a rc:LayoutVerificationStatus ;
    rdfs:label "unverified layout" ;
    rdfs:comment "The layout/path metadata is useful for orientation but has not yet been checked against the source system." .

rc:GeneratedFromManifestLayout a rc:LayoutVerificationStatus ;
    rdfs:label "generated from manifest" ;
    rdfs:comment "The layout/path metadata was generated from source manifest or documentation, but has not been independently checked against storage or query results." .

rc:CandidateLayout a rc:LayoutVerificationStatus ;
    rdfs:label "candidate layout" ;
    rdfs:comment "The layout/path metadata is a plausible candidate or competing hypothesis, not yet the accepted map fact." .

rc:VerifiedByListingLayout a rc:LayoutVerificationStatus ;
    rdfs:label "verified by listing" ;
    rdfs:comment "The layout/path metadata has been checked against a storage directory or object listing." .

rc:VerifiedByQueryLayout a rc:LayoutVerificationStatus ;
    rdfs:label "verified by query" ;
    rdfs:comment "The layout/path metadata has been checked by successfully querying or reading representative data." .

rc:ContradictedLayout a rc:LayoutVerificationStatus ;
    rdfs:label "contradicted layout" ;
    rdfs:comment "The layout/path metadata conflicts with source evidence and should not be used without review." .

rc:Ascending a rc:SortDirection ; rdfs:label "ascending" .
rc:Descending a rc:SortDirection ; rdfs:label "descending" .

rc:ClusteringForIndex a rc:OrderingSemanticType ;
    rdfs:comment "Ordering groups values for index or storage efficiency." .

rc:MeaningfulSequence a rc:OrderingSemanticType ;
    rdfs:comment "Ordering carries domain meaning, such as temporal sequence." .

rc:PerformanceOnly a rc:OrderingSemanticType ;
    rdfs:comment "Ordering exists solely for query performance." .

rc:Daily a rc:TemporalGranularity ; rdfs:label "daily" .
rc:Hourly a rc:TemporalGranularity ; rdfs:label "hourly" .
rc:Monthly a rc:TemporalGranularity ; rdfs:label "monthly" .
rc:ByValue a rc:TemporalGranularity ; rdfs:label "by value" .

# -----------------------------------------------------------------------------
# Observations, evidence, and lightweight provenance
# -----------------------------------------------------------------------------

rc:Observation a rdfs:Class ;
    rdfs:comment "A point-in-time, tentative, or source-scoped finding." .

rc:ProfileObservation a rdfs:Class ;
    rdfs:subClassOf rc:Observation ;
    rdfs:comment "An observation produced by profiling a data asset, table, file, or column." .

rc:ObservedValueFrequency a rdfs:Class ;
    rdfs:comment "A profiled value or value bucket paired with its observed frequency for one profile observation." .

rc:ObservedProfileMetric a rdfs:Class ;
    rdfs:comment "A named scalar profile metric, such as an observed minimum, maximum, mean, or median value." .

rc:ProfileMetricKind a rdfs:Class ;
    rdfs:comment "A reusable kind of scalar profile metric. Projects may define additional metric kinds in their own ontology graph." .

rc:Evidence a rdfs:Class ;
    rdfs:comment "A record that supports an observation or map assertion." .

rc:Claim a rdfs:Class ;
    rdfs:comment "A structured claim made by an observation. Claims let agents express nuanced dataset lore as RDF rather than only prose." .

rc:Pattern a rdfs:Class ;
    rdfs:comment "A synthesis over observations, claims, or evidence that explains a recurring or connected dataset pattern. Patterns bridge point-in-time findings and the current project map." .

rc:ClaimKind a rdfs:Class ;
    rdfs:comment "Controlled category for the kind of claim an observation is making." .

rc:ConfidenceLevel a rdfs:Class ;
    rdfs:comment "Controlled confidence level for an observed claim." .

rc:PatternStability a rdfs:Class ;
    rdfs:comment "Controlled indication of how durable or repeatable a pattern appears to be." .

rc:ObservationStatus a rdfs:Class ;
    rdfs:comment "Lifecycle status for an observation or claim." .

rc:ClaimReconsideration a rdfs:Class ;
    rdfs:comment "A record that one claim has weakened, contradicted, superseded, or refined an earlier claim." .

rc:ClaimReconsiderationRelation a rdfs:Class ;
    rdfs:comment "Controlled relation type for claim reconsideration records." .

rc:SourceSpan a rdfs:Class ;
    rdfs:comment "A bounded location in a source document, query, code file, data sample, or external resource." .

rc:SourceKind a rdfs:Class ;
    rdfs:comment "Controlled category for the kind of source used as evidence." .

rc:Provenance a rdfs:Class ;
    rdfs:comment "Lightweight source and transformation information for a data asset." .

rc:Transformation a rdfs:Class ;
    rdfs:comment "A transformation applied to create, clean, move, or derive data." .

rc:VerificationAttestation a rdfs:Class ;
    rdfs:comment "A record of a validation or verification run." .

rc:VerificationResultValue a rdfs:Class ;
    rdfs:comment "Outcome of a verification run." .

rc:observedAt a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "When an observation was made." .

rc:observedBy a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "The agent, tool, process, or person that made an observation." .

rc:observedAsset a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range rc:DataAsset ;
    rdfs:comment "The data asset observed." .

rc:observedColumn a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range rc:Column ;
    rdfs:comment "The column observed." .

rc:observedColumnName a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:string ;
    rdfs:comment "The source-level column name supplied with an observed column, useful when the column is not yet a current map column." .

rc:observedPhysicalType a rdf:Property ;
    rdfs:domain rc:ProfileObservation ;
    rdfs:range rc:PhysicalType ;
    rdfs:comment "A physical type observed during profiling. This is profile evidence, not a current map assertion." .

rc:observedValueType a rdf:Property ;
    rdfs:domain rc:ProfileObservation ;
    rdfs:range rc:ValueType ;
    rdfs:comment "A value type interpretation observed during profiling. This is profile evidence, not a current map assertion." .

rc:sampleSize a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:integer ;
    rdfs:comment "Number of records, rows, values, or items sampled for an observation." .

rc:sampleScope a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:string ;
    rdfs:comment "Short description of the population, file set, query result, or slice covered by a sample or profile observation." .

rc:sampleMethod a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:string ;
    rdfs:comment "Short description of how the sample or profile observation was produced, such as full scan, random sample, stratified sample, or top-N query." .

rc:rowCount a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:integer ;
    rdfs:comment "Observed row count." .

rc:nullCount a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:integer ;
    rdfs:comment "Observed null count." .

rc:distinctCount a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range xsd:integer ;
    rdfs:comment "Observed distinct-value count." .

rc:observedProfileMetric a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range rc:ObservedProfileMetric ;
    rdfs:comment "Links a profile observation to a named scalar metric value." .

rc:profileMetricKind a rdf:Property ;
    rdfs:domain rc:ObservedProfileMetric ;
    rdfs:range rc:ProfileMetricKind ;
    rdfs:comment "The kind of scalar metric being recorded." .

rc:profileMetricTarget a rdf:Property ;
    rdfs:domain rc:ObservedProfileMetric ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Optional resource the scalar metric is specifically about, when narrower than or different from the profile observation as a whole." .

rc:profileMetricValue a rdf:Property ;
    rdfs:domain rc:ObservedProfileMetric ;
    rdfs:comment "The observed scalar metric value." .

rc:observedValueFrequency a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range rc:ObservedValueFrequency ;
    rdfs:comment "Links a profile observation to a value or bucket with its observed frequency." .

rc:observedValue a rdf:Property ;
    rdfs:comment "A value observed during profiling. This is not a declared allowed value." .

rc:valueFrequency a rdf:Property ;
    rdfs:domain rc:ObservedValueFrequency ;
    rdfs:range xsd:integer ;
    rdfs:comment "Observed frequency for a value or value bucket." .

rc:evidence a rdf:Property ;
    rdfs:range rc:Evidence ;
    rdfs:comment "Links an observation or assertion to supporting evidence." .

rc:hasClaim a rdf:Property ;
    rdfs:domain rc:Observation ;
    rdfs:range rc:Claim ;
    rdfs:comment "Links an observation to one or more structured RDF claims." .

rc:claimKind a rdf:Property ;
    rdfs:domain rc:Claim ;
    rdfs:range rc:ClaimKind ;
    rdfs:comment "The category of claim being made." .

rc:claimText a rdf:Property ;
    rdfs:domain rc:Claim ;
    rdfs:range xsd:string ;
    rdfs:comment "A concise human-readable rendering of the claim." .

rc:claimTarget a rdf:Property ;
    rdfs:domain rc:Claim ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "The resource that the claim is primarily about." .

rc:patternText a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range xsd:string ;
    rdfs:comment "A concise human-readable rendering of the pattern." .

rc:rationale a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range xsd:string ;
    rdfs:comment "Reasoning that explains why observations, claims, or evidence belong together." .

rc:patternTarget a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "A resource the pattern is primarily about." .

rc:supportingObservation a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range rc:Observation ;
    rdfs:comment "An observation that supports a pattern." .

rc:supportingClaim a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range rc:Claim ;
    rdfs:comment "A structured claim that supports a pattern." .

rc:patternStability a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range rc:PatternStability ;
    rdfs:comment "How repeatable, durable, or invariant the pattern currently appears." .

rc:mapImplication a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "A map resource or named candidate map implication suggested by a pattern without requiring an immediate map edit." .

rc:synthesizedAt a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "When a pattern synthesis was recorded." .

rc:synthesizedBy a rdf:Property ;
    rdfs:domain rc:Pattern ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "The agent, tool, process, or person that synthesized a pattern." .

rc:proposedAssertion a rdf:Property ;
    rdfs:domain rc:Claim ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "A resource representing a candidate durable assertion that may later be promoted into a map or ontology graph." .

rc:confidence a rdf:Property ;
    rdfs:range rc:ConfidenceLevel ;
    rdfs:comment "Confidence level for a structured claim or pattern synthesis." .

rc:observationStatus a rdf:Property ;
    rdfs:range rc:ObservationStatus ;
    rdfs:comment "Lifecycle status for an observation or claim." .

rc:supports a rdf:Property ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Links an observation, claim, or evidence record to something it supports." .

rc:contradicts a rdf:Property ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Links an observation or claim to an earlier claim or assertion it contradicts." .

rc:refines a rdf:Property ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Links an observation or claim to an earlier claim or assertion it narrows, qualifies, or improves." .

rc:weakens a rdf:Property ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Links a claim to an earlier claim or assertion it makes less certain, broad, or durable without fully contradicting it." .

rc:supersedes a rdf:Property ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Links a claim to an earlier claim or assertion it replaces as the better current interpretation." .

rc:reconsideringClaim a rdf:Property ;
    rdfs:domain rc:ClaimReconsideration ;
    rdfs:range rc:Claim ;
    rdfs:comment "The newer claim that reconsiders an earlier claim." .

rc:reconsideredClaim a rdf:Property ;
    rdfs:domain rc:ClaimReconsideration ;
    rdfs:range rc:Claim ;
    rdfs:comment "The earlier claim being weakened, contradicted, superseded, or refined." .

rc:reconsiderationRelation a rdf:Property ;
    rdfs:domain rc:ClaimReconsideration ;
    rdfs:range rc:ClaimReconsiderationRelation ;
    rdfs:comment "The kind of reconsideration relation between the newer and older claim." .

rc:reconsiderationRationale a rdf:Property ;
    rdfs:domain rc:ClaimReconsideration ;
    rdfs:range xsd:string ;
    rdfs:comment "Why the newer claim should change how the older claim is read." .

rc:reconsideredAt a rdf:Property ;
    rdfs:domain rc:ClaimReconsideration ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "When the reconsideration was recorded." .

rc:reconsideredBy a rdf:Property ;
    rdfs:domain rc:ClaimReconsideration ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "The agent, tool, process, or person that recorded the reconsideration." .

rc:sourceSpan a rdf:Property ;
    rdfs:domain rc:Evidence ;
    rdfs:range rc:SourceSpan ;
    rdfs:comment "Links evidence to a bounded source location." .

rc:sourcePath a rdf:Property ;
    rdfs:domain rc:SourceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Path, URI, object key, or other non-secret source locator." .

rc:sourceSection a rdf:Property ;
    rdfs:domain rc:SourceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Heading, section label, table name, query name, or other local source section." .

rc:startLine a rdf:Property ;
    rdfs:domain rc:SourceSpan ;
    rdfs:range xsd:integer ;
    rdfs:comment "One-based inclusive starting line for a source span." .

rc:endLine a rdf:Property ;
    rdfs:domain rc:SourceSpan ;
    rdfs:range xsd:integer ;
    rdfs:comment "One-based inclusive ending line for a source span." .

rc:sourceKind a rdf:Property ;
    rdfs:domain rc:SourceSpan ;
    rdfs:range rc:SourceKind ;
    rdfs:comment "The kind of source being cited." .

rc:queryExecutionStatus a rdf:Property ;
    rdfs:domain rc:Evidence ;
    rdfs:range xsd:string ;
    rdfs:comment "Execution status for evidence produced by an external query attempt." .

rc:queryEngine a rdf:Property ;
    rdfs:domain rc:Evidence ;
    rdfs:range xsd:string ;
    rdfs:comment "Runtime or tool that produced evidence from an external query attempt." .

rc:queryHash a rdf:Property ;
    rdfs:domain rc:Evidence ;
    rdfs:range xsd:string ;
    rdfs:comment "Hash or fingerprint of the external query text when available." .

rc:summary a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:comment "A concise human-readable summary." .

rc:hasProvenance a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:Provenance ;
    rdfs:comment "Links a data asset to lightweight provenance information." .

rc:source a rdf:Property ;
    rdfs:domain rc:Provenance ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "The upstream source resource." .

rc:sourceDescription a rdf:Property ;
    rdfs:domain rc:Provenance ;
    rdfs:range xsd:string ;
    rdfs:comment "A free-text description of the upstream source." .

rc:hasTransformation a rdf:Property ;
    rdfs:domain rc:Provenance ;
    rdfs:range rc:Transformation ;
    rdfs:comment "Links provenance to a transformation." .

rc:transformationType a rdf:Property ;
    rdfs:domain rc:Transformation ;
    rdfs:range xsd:string ;
    rdfs:comment "A compact type or category for a transformation." .

rc:transformationDescription a rdf:Property ;
    rdfs:domain rc:Transformation ;
    rdfs:range xsd:string ;
    rdfs:comment "A human-readable description of a transformation." .

rc:verifiedConstraint a rdf:Property ;
    rdfs:domain rc:VerificationAttestation ;
    rdfs:range rc:Constraint .

rc:verifiedAsset a rdf:Property ;
    rdfs:domain rc:VerificationAttestation ;
    rdfs:range rc:DataAsset .

rc:verificationTime a rdf:Property ;
    rdfs:domain rc:VerificationAttestation ;
    rdfs:range xsd:dateTime .

rc:verificationResult a rdf:Property ;
    rdfs:domain rc:VerificationAttestation ;
    rdfs:range rc:VerificationResultValue .

rc:verificationTool a rdf:Property ;
    rdfs:domain rc:VerificationAttestation ;
    rdfs:range rdfs:Resource .

rc:verificationDetails a rdf:Property ;
    rdfs:domain rc:VerificationAttestation ;
    rdfs:range xsd:string .

rc:Pass a rc:VerificationResultValue ; rdfs:label "pass" .
rc:Fail a rc:VerificationResultValue ; rdfs:label "fail" .
rc:Partial a rc:VerificationResultValue ; rdfs:label "partial" .
rc:Error a rc:VerificationResultValue ; rdfs:label "error" .

rc:CaveatClaim a rc:ClaimKind ; rdfs:label "caveat claim" .
rc:JoinClaim a rc:ClaimKind ; rdfs:label "join claim" .
rc:SchemaClaim a rc:ClaimKind ; rdfs:label "schema claim" .
rc:TransformationClaim a rc:ClaimKind ; rdfs:label "transformation claim" .
rc:AccessClaim a rc:ClaimKind ; rdfs:label "access claim" .
rc:ProfileClaim a rc:ClaimKind ; rdfs:label "profile claim" .
rc:InterpretationClaim a rc:ClaimKind ; rdfs:label "interpretation claim" .

rc:MinimumValue a rc:ProfileMetricKind ; rdfs:label "minimum value" .
rc:MaximumValue a rc:ProfileMetricKind ; rdfs:label "maximum value" .
rc:MeanValue a rc:ProfileMetricKind ; rdfs:label "mean value" .
rc:MedianValue a rc:ProfileMetricKind ; rdfs:label "median value" .
rc:StandardDeviationValue a rc:ProfileMetricKind ; rdfs:label "standard deviation value" .

rc:LowConfidence a rc:ConfidenceLevel ; rdfs:label "low confidence" .
rc:MediumConfidence a rc:ConfidenceLevel ; rdfs:label "medium confidence" .
rc:HighConfidence a rc:ConfidenceLevel ; rdfs:label "high confidence" .

rc:EmergingPattern a rc:PatternStability ; rdfs:label "emerging pattern" .
rc:RepeatedPattern a rc:PatternStability ; rdfs:label "repeated pattern" .
rc:InvariantPattern a rc:PatternStability ; rdfs:label "invariant pattern" .

rc:Tentative a rc:ObservationStatus ; rdfs:label "tentative" .
rc:Checked a rc:ObservationStatus ; rdfs:label "checked" .
rc:Weakened a rc:ObservationStatus ; rdfs:label "weakened" .
rc:Contradicted a rc:ObservationStatus ; rdfs:label "contradicted" .
rc:Superseded a rc:ObservationStatus ; rdfs:label "superseded" .
rc:Promoted a rc:ObservationStatus ; rdfs:label "promoted" .

rc:Weakening a rc:ClaimReconsiderationRelation ; rdfs:label "weakening" .
rc:Contradiction a rc:ClaimReconsiderationRelation ; rdfs:label "contradiction" .
rc:Supersession a rc:ClaimReconsiderationRelation ; rdfs:label "supersession" .
rc:Refinement a rc:ClaimReconsiderationRelation ; rdfs:label "refinement" .

rc:DocumentationSource a rc:SourceKind ; rdfs:label "documentation source" .
rc:QuerySource a rc:SourceKind ; rdfs:label "query source" .
rc:DataSampleSource a rc:SourceKind ; rdfs:label "data sample source" .
rc:CodeSource a rc:SourceKind ; rdfs:label "code source" .
rc:StorageSource a rc:SourceKind ; rdfs:label "storage source" .
rc:DoxaBaseAPISource a rc:SourceKind ; rdfs:label "DoxaBase API source" .

# -----------------------------------------------------------------------------
# History and revisions
# -----------------------------------------------------------------------------

rc:GraphRevision a rdfs:Class ;
    rdfs:comment "Metadata for a graph change, consolidation step, review bundle, or other revision event recorded in the history graph." .

rc:GraphSnapshot a rdfs:Class ;
    rdfs:comment "A point-in-time count summary for one graph role within a revision record." .

rc:GraphPatch a rdfs:Class ;
    rdfs:comment "A staged addition or removal payload attached to a graph revision for review before any durable graph mutation." .

rc:RevisionType a rdfs:Class ;
    rdfs:comment "A compact category for a graph revision or history event." .

rc:RevisionStance a rdfs:Class ;
    rdfs:comment "The epistemic or creative posture of a staged revision, such as exploratory hunch, candidate revision, or conservative cleanup." .

rc:StagedRevisionRecoverySession a rdfs:Class ;
    rdfs:comment "A durable history resource that groups staged revision recovery sources, handoff context, and planning parameters so agents can replan a multi-step recovery workflow over time." .

rc:GraphPatchOperation a rdfs:Class ;
    rdfs:comment "A compact operation type for a staged graph patch." .

rc:GraphPatchRole a rdfs:Class ;
    rdfs:comment "A compact role for a staged graph patch, such as shared proposed context or framing-specific payload." .

rc:revisionType a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:RevisionType ;
    rdfs:comment "The category of graph revision or history event." .

rc:revisionStance a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:RevisionStance ;
    rdfs:comment "The stance of a staged revision: how bold, exploratory, conservative, or superseded the proposal is." .

rc:revisionRationale a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "Why the graph change, consolidation, or review bundle was created." .

rc:reviewNote a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "A concise reviewer-facing note about what this revision is doing or why it matters." .

rc:reviewRecommendation a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "A provisional recommendation or disposition for a staged revision, such as preferred for now, keep as alternative, or reject this framing." .

rc:profileInsightRouteSource a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "JSON profile-route source metadata captured when a staged revision is created from profile insight review flow, so post-apply review bundles can preserve the original route bridge." .

rc:alternativeTo a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:GraphRevision ;
    rdfs:comment "Links a staged revision to an alternative staged or historical revision it competes with, refines, or supersedes." .

rc:restagesRevision a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:GraphRevision ;
    rdfs:comment "Links a staged revision to an earlier staged revision whose patch intent it replays against a newer graph state." .

rc:appliesStagedRevision a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:GraphRevision ;
    rdfs:comment "Links an applied revision event to the staged graph revision it applied." .

rc:sessionCreatedAt a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "When a durable workflow session was started." .

rc:sessionCreatedBy a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Agent, person, or process that started a durable workflow session." .

rc:recoverySessionSourceRevision a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range rc:GraphRevision ;
    rdfs:comment "A staged, restaged, or applied graph revision included in a staged recovery session." .

rc:recoverySessionSourceRevisionList a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:string ;
    rdfs:comment "JSON-encoded ordered source revision IRI list for deterministic recovery-session replanning." .

rc:recoverySessionSourceCount a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:integer ;
    rdfs:comment "Number of source revisions captured when a staged recovery session was started." .

rc:recoverySessionHandoffManifestPath a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:string ;
    rdfs:comment "Local path to the handoff manifest associated with a staged recovery session, when known." .

rc:recoverySessionInitialSelectionMode a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:string ;
    rdfs:comment "The recovery-plan selection mode used when a staged recovery session was started." .

rc:recoverySessionCurrentStagedWorkOnly a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the session was started from the current-staged-work-only recovery view." .

rc:recoverySessionIncludeDrafts a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether recovery-session replans should include read-only repair drafts by default." .

rc:recoverySessionValidationScope a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:string ;
    rdfs:comment "Validation scope used for recovery-session replans when one was supplied." .

rc:recoverySessionDriftDetail a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:string ;
    rdfs:comment "Drift detail level used for recovery-session replans." .

rc:recoverySessionInitialLaneCounts a rdf:Property ;
    rdfs:domain rc:StagedRevisionRecoverySession ;
    rdfs:range xsd:string ;
    rdfs:comment "JSON-encoded lane counts from the initial staged recovery plan." .

rc:changedGraph a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "A graph role whose contents changed or were consolidated in a revision event." .

rc:includedGraph a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "A graph role included in a review, validation, export, or snapshot context for a revision event." .

rc:createdAt a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "When a revision event was recorded." .

rc:createdBy a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Agent, person, or process that recorded a revision event." .

rc:revisionSupportingObservation a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:Observation ;
    rdfs:comment "An observation that supports a graph revision." .

rc:revisionSupportingClaim a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:Claim ;
    rdfs:comment "A structured claim that supports a graph revision." .

rc:revisionSupportingPattern a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:Pattern ;
    rdfs:comment "A pattern that supports a graph revision." .

rc:revisionAnchor a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "A resource the revision is about, without implying that the resource is evidence or support for the change." .

rc:hasGraphPatch a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:GraphPatch ;
    rdfs:comment "Links a staged revision to one addition or removal payload." .

rc:hasGraphSnapshot a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range rc:GraphSnapshot ;
    rdfs:comment "Links a revision event to point-in-time graph role counts." .

rc:graphRole a rdf:Property ;
    rdfs:domain rc:GraphSnapshot ;
    rdfs:range xsd:string ;
    rdfs:comment "The named graph role summarized by a graph snapshot." .

rc:tripleCount a rdf:Property ;
    rdfs:domain rc:GraphSnapshot ;
    rdfs:range xsd:integer ;
    rdfs:comment "Triple count for one graph role at the time a revision was recorded." .

rc:contentDigest a rdf:Property ;
    rdfs:domain rc:GraphSnapshot ;
    rdfs:range xsd:string ;
    rdfs:comment "A digest of the graph role contents at the time a revision snapshot was recorded, written as algorithm-prefixed text such as sha256:<hex>." .

rc:patchOperation a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range rc:GraphPatchOperation ;
    rdfs:comment "Whether a staged graph patch adds or removes triples." .

rc:targetGraph a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:string ;
    rdfs:comment "The mutable graph role targeted by a staged patch." .

rc:patchFormat a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:string ;
    rdfs:comment "The RDF serialization format of patchContent, usually turtle." .

rc:patchRole a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range rc:GraphPatchRole ;
    rdfs:comment "Whether a staged graph patch is framing-specific payload or shared proposed context for related framings." .

rc:patchSequence a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:integer ;
    rdfs:comment "One-based order in which a staged patch was previewed and should be checked/applied." .

rc:patchContent a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:string ;
    rdfs:comment "The RDF payload for a staged addition or removal." .

rc:patchTripleCount a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:integer ;
    rdfs:comment "Number of triples parsed from the staged patch payload." .

rc:beforeTripleCount a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:integer ;
    rdfs:comment "Triple count for the target graph before this staged patch is previewed." .

rc:afterTripleCount a rdf:Property ;
    rdfs:domain rc:GraphPatch ;
    rdfs:range xsd:integer ;
    rdfs:comment "Triple count for the target graph after this staged patch is previewed." .

rc:exportPath a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "Path to an exported review artifact associated with a revision event." .

rc:validationScope a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:string ;
    rdfs:comment "Validation scope checked for a revision event." .

rc:validationConforms a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether validation conformed for a revision event." .

rc:validationResultCount a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range xsd:integer ;
    rdfs:comment "Number of validation results reported for a revision event." .

rc:hasValidationResult a rdf:Property ;
    rdfs:domain rc:GraphRevision ;
    rdfs:range sh:ValidationResult ;
    rdfs:comment "Links a revision event to structured SHACL validation result details captured during validation." .

rc:ManualRevision a rc:RevisionType ; rdfs:label "manual revision" .
rc:ImportRevision a rc:RevisionType ; rdfs:label "import revision" .
rc:ExportRevision a rc:RevisionType ; rdfs:label "export revision" .
rc:MapAuthoringRevision a rc:RevisionType ; rdfs:label "map authoring revision" .
rc:FieldTrialRevision a rc:RevisionType ; rdfs:label "field trial revision" .
rc:StagedRevision a rc:RevisionType ; rdfs:label "staged revision" .
rc:AppliedStagedRevision a rc:RevisionType ; rdfs:label "applied staged revision" .

rc:ExploratoryHunch a rc:RevisionStance ; rdfs:label "exploratory hunch" .
rc:CandidateRevision a rc:RevisionStance ; rdfs:label "candidate revision" .
rc:ConservativeCleanup a rc:RevisionStance ; rdfs:label "conservative cleanup" .
rc:AlternativeSystematisation a rc:RevisionStance ; rdfs:label "alternative systematisation" .
rc:SupersededRevision a rc:RevisionStance ; rdfs:label "superseded revision" .

rc:AdditionPatch a rc:GraphPatchOperation ; rdfs:label "addition patch" .
rc:RemovalPatch a rc:GraphPatchOperation ; rdfs:label "removal patch" .

rc:FramingPatch a rc:GraphPatchRole ; rdfs:label "framing patch" .
rc:SharedContextPatch a rc:GraphPatchRole ; rdfs:label "shared context patch" .

# -----------------------------------------------------------------------------
# Caveats
# -----------------------------------------------------------------------------

rc:KnownCaveat a rdfs:Class ;
    rdfs:comment "A known caveat, deficiency, unstable assumption, broken expectation, or non-obvious interpretation rule." .

rc:SeverityLevel a rdfs:Class ;
    rdfs:comment "Severity of a caveat or validation finding." .

rc:hasKnownCaveat a rdf:Property ;
    rdfs:domain rc:DataAsset ;
    rdfs:range rc:KnownCaveat ;
    rdfs:comment "Links a data asset to a known caveat." .

rc:caveatDescription a rdf:Property ;
    rdfs:domain rc:KnownCaveat ;
    rdfs:range xsd:string ;
    rdfs:comment "Description of a caveat." .

rc:violatedExpectation a rdf:Property ;
    rdfs:domain rc:KnownCaveat ;
    rdfs:range rc:Constraint ;
    rdfs:comment "The expectation, rule, or constraint that does not hold." .

rc:impact a rdf:Property ;
    rdfs:domain rc:KnownCaveat ;
    rdfs:range xsd:string ;
    rdfs:comment "Downstream impact of a caveat." .

rc:severity a rdf:Property ;
    rdfs:range rc:SeverityLevel ;
    rdfs:comment "Severity of a caveat or validation finding." .

rc:Minor a rc:SeverityLevel ; rdfs:label "minor" .
rc:Moderate a rc:SeverityLevel ; rdfs:label "moderate" .
rc:Severe a rc:SeverityLevel ; rdfs:label "severe" .
