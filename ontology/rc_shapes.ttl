@prefix rc:   <https://richcanopy.org/ns/rc#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Rich Canopy base SHACL shapes.
#
# These shapes validate common authoring mistakes in graphs that choose to use
# rc: terms. They are intentionally open: they do not use sh:closed, they do not
# reject client-defined properties, and they should be run as an explicit
# diagnostic rather than as a mandatory V1 commit gate.

rc:DataAssetShape a sh:NodeShape ;
    sh:targetClass rc:DataAsset ;
    sh:property [
        sh:path rdfs:label ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "A data asset should have at most one string rdfs:label." ;
    ] ;
    sh:property [
        sh:path rc:rowCountSnapshot ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "rowCountSnapshot must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:schemaStability ;
        sh:maxCount 1 ;
        sh:in ( rc:FixedSchema rc:InferredSchema rc:VariableSchema ) ;
        sh:message "schemaStability must be FixedSchema, InferredSchema, or VariableSchema." ;
    ] ;
    sh:property [
        sh:path rc:hasKnownCaveat ;
        sh:nodeKind sh:IRI ;
        sh:message "hasKnownCaveat values should be named caveat resources." ;
    ] ;
    sh:property [
        sh:path rc:hasStorageAccess ;
        sh:nodeKind sh:IRI ;
        sh:message "hasStorageAccess values should be named storage access resources." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationStatus ;
        sh:maxCount 1 ;
        sh:in (
            rc:UnverifiedLayout
            rc:GeneratedFromManifestLayout
            rc:CandidateLayout
            rc:VerifiedByListingLayout
            rc:VerifiedByQueryLayout
            rc:ContradictedLayout
        ) ;
        sh:message "layoutVerificationStatus must be a known layout verification status." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationNote ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "layoutVerificationNote must be a single string if declared." ;
    ] .

rc:TableShape a sh:NodeShape ;
    sh:targetClass rc:Table ;
    sh:property [
        sh:path rc:hasColumn ;
        sh:nodeKind sh:IRI ;
        sh:message "Table columns should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:rowSemantics ;
        sh:maxCount 1 ;
        sh:in ( rc:EventRow rc:SnapshotRow rc:AggregateRow rc:DimensionRow ) ;
        sh:message "rowSemantics must be EventRow, SnapshotRow, AggregateRow, or DimensionRow." ;
    ] ;
    sh:property [
        sh:path rc:entityKey ;
        sh:nodeKind sh:IRI ;
        sh:message "entityKey values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:snapshotTimestamp ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "snapshotTimestamp should be a named column resource." ;
    ] .

rc:ColumnShape a sh:NodeShape ;
    sh:targetClass rc:Column ;
    sh:property [
        sh:path rc:columnName ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "columnName must be a single string if declared." ;
    ] ;
    sh:property [
        sh:path rc:physicalType ;
        sh:maxCount 1 ;
        sh:class rc:PhysicalType ;
        sh:message "physicalType must be an rc:PhysicalType." ;
    ] ;
    sh:property [
        sh:path rc:valueType ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "valueType should point to a named value-type resource." ;
    ] ;
    sh:property [
        sh:path rc:nullable ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "nullable must be a boolean if declared." ;
    ] ;
    sh:property [
        sh:path rc:caseConvention ;
        sh:maxCount 1 ;
        sh:in ( rc:UpperCase rc:LowerCase rc:MixedCase ) ;
        sh:message "caseConvention must be UpperCase, LowerCase, or MixedCase." ;
    ] ;
    sh:property [
        sh:path rc:embeddedStructure ;
        sh:maxCount 1 ;
        sh:node rc:EmbeddedStructureShape ;
        sh:message "embeddedStructure must match rc:EmbeddedStructureShape." ;
    ] .

rc:ColumnGroupShape a sh:NodeShape ;
    sh:targetClass rc:ColumnGroup ;
    sh:property [
        sh:path rc:groupMember ;
        sh:nodeKind sh:IRI ;
        sh:message "groupMember values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:groupValueType ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "groupValueType should point to a named value-type resource." ;
    ] .

rc:ValueTypeShape a sh:NodeShape ;
    sh:targetClass rc:ValueType ;
    sh:property [
        sh:path rdfs:label ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "A value type should have at most one string rdfs:label." ;
    ] ;
    sh:property [
        sh:path rc:requiredPhysicalType ;
        sh:maxCount 1 ;
        sh:class rc:PhysicalType ;
        sh:message "requiredPhysicalType must be an rc:PhysicalType." ;
    ] ;
    sh:property [
        sh:path rc:acceptablePhysicalType ;
        sh:class rc:PhysicalType ;
        sh:message "acceptablePhysicalType values must be rc:PhysicalType resources." ;
    ] ;
    sh:property [
        sh:path rc:valueRange ;
        sh:maxCount 1 ;
        sh:node rc:ValueRangeShape ;
        sh:message "valueRange must match rc:ValueRangeShape." ;
    ] ;
    sh:property [
        sh:path rc:unit ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "unit must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:identifierNamespace ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "identifierNamespace must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:hasAllowedValues ;
        sh:maxCount 1 ;
        sh:node rc:AllowedValuesShape ;
        sh:message "hasAllowedValues must match rc:AllowedValuesShape." ;
    ] .

rc:ValueRangeShape a sh:NodeShape ;
    sh:targetClass rc:ValueRange ;
    sh:or (
        [ sh:property [ sh:path rc:minInclusive ; sh:minCount 1 ] ]
        [ sh:property [ sh:path rc:maxInclusive ; sh:minCount 1 ] ]
        [ sh:property [ sh:path rc:minExclusive ; sh:minCount 1 ] ]
        [ sh:property [ sh:path rc:maxExclusive ; sh:minCount 1 ] ]
    ) ;
    sh:property [
        sh:path rc:minInclusive ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rc:maxInclusive ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rc:minExclusive ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rc:maxExclusive ;
        sh:maxCount 1 ;
    ] ;
    sh:message "ValueRange must declare at least one bound." .

rc:AllowedValuesShape a sh:NodeShape ;
    sh:targetClass rc:AllowedValues ;
    sh:property [
        sh:path rc:allowedValue ;
        sh:minCount 1 ;
        sh:message "AllowedValues must declare at least one allowedValue." ;
    ] .

rc:EmbeddedStructureShape a sh:NodeShape ;
    sh:targetClass rc:EmbeddedStructure ;
    sh:property [
        sh:path rc:embeddedFormat ;
        sh:maxCount 1 ;
        sh:class rc:DataEncodingFormat ;
        sh:message "embeddedFormat must be an rc:DataEncodingFormat." ;
    ] ;
    sh:property [
        sh:path rc:embeddedElementType ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "embeddedElementType must be a string if declared." ;
    ] .

rc:ForeignKeyShape a sh:NodeShape ;
    sh:targetClass rc:ForeignKey ;
    sh:property [
        sh:path rc:foreignKeyFrom ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "ForeignKey must have exactly one named foreignKeyFrom column." ;
    ] ;
    sh:property [
        sh:path rc:foreignKeyTo ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "ForeignKey must have exactly one named foreignKeyTo column." ;
    ] ;
    sh:property [
        sh:path rc:declared ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "declared must be a boolean if supplied." ;
    ] ;
    sh:property [
        sh:path rc:referentialIntegrity ;
        sh:maxCount 1 ;
        sh:in ( rc:StrictIntegrity rc:EventualIntegrity rc:PartialIntegrity ) ;
        sh:message "referentialIntegrity must be StrictIntegrity, EventualIntegrity, or PartialIntegrity." ;
    ] .

rc:SharedIdentifierShape a sh:NodeShape ;
    sh:targetClass rc:SharedIdentifier ;
    sh:property [
        sh:path rc:identifyingColumn ;
        sh:minCount 2 ;
        sh:nodeKind sh:IRI ;
        sh:message "SharedIdentifier should link at least two named identifying columns." ;
    ] .

rc:DerivationShape a sh:NodeShape ;
    sh:targetClass rc:Derivation ;
    sh:property [
        sh:path rc:derivedColumn ;
        sh:nodeKind sh:IRI ;
        sh:message "derivedColumn values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:sourceColumn ;
        sh:nodeKind sh:IRI ;
        sh:message "sourceColumn values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:hasDerivationProperty ;
        sh:in ( rc:Deterministic rc:Invertible rc:Lossy ) ;
        sh:message "hasDerivationProperty values should be Deterministic, Invertible, or Lossy." ;
    ] .

rc:AggregationShape a sh:NodeShape ;
    sh:targetClass rc:Aggregation ;
    sh:property [
        sh:path rc:sourceDataset ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "sourceDataset should be a named data asset resource." ;
    ] ;
    sh:property [
        sh:path rc:targetDataset ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "targetDataset should be a named data asset resource." ;
    ] ;
    sh:property [
        sh:path rc:groupByColumn ;
        sh:nodeKind sh:IRI ;
        sh:message "groupByColumn values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:hasAggregatedColumn ;
        sh:node rc:AggregatedColumnShape ;
        sh:message "hasAggregatedColumn values should match rc:AggregatedColumnShape." ;
    ] .

rc:AggregatedColumnShape a sh:NodeShape ;
    sh:targetClass rc:AggregatedColumn ;
    sh:property [
        sh:path rc:targetColumn ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "AggregatedColumn must name exactly one targetColumn." ;
    ] ;
    sh:property [
        sh:path rc:aggregationSourceColumn ;
        sh:nodeKind sh:IRI ;
        sh:message "aggregationSourceColumn values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:withinGroupOrdering ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "withinGroupOrdering should be a named column resource." ;
    ] .

rc:PhysicalLayoutShape a sh:NodeShape ;
    sh:targetClass rc:PhysicalLayout ;
    sh:property [
        sh:path rc:fileFormat ;
        sh:maxCount 1 ;
        sh:class rc:FileFormat ;
        sh:message "fileFormat must be an rc:FileFormat if declared." ;
    ] ;
    sh:property [
        sh:path rc:compressionCodec ;
        sh:maxCount 1 ;
        sh:class rc:CompressionCodec ;
        sh:message "compressionCodec must be an rc:CompressionCodec if declared." ;
    ] ;
    sh:property [
        sh:path rc:hasRowOrdering ;
        sh:maxCount 1 ;
        sh:node rc:RowOrderingShape ;
        sh:message "hasRowOrdering must match rc:RowOrderingShape." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationStatus ;
        sh:maxCount 1 ;
        sh:in (
            rc:UnverifiedLayout
            rc:GeneratedFromManifestLayout
            rc:CandidateLayout
            rc:VerifiedByListingLayout
            rc:VerifiedByQueryLayout
            rc:ContradictedLayout
        ) ;
        sh:message "layoutVerificationStatus must be a known layout verification status." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationNote ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "layoutVerificationNote must be a single string if declared." ;
    ] .

rc:RowOrderingShape a sh:NodeShape ;
    sh:targetClass rc:RowOrdering ;
    sh:property [
        sh:path rc:hasOrderingKey ;
        sh:node rc:OrderingKeyShape ;
        sh:message "hasOrderingKey values must match rc:OrderingKeyShape." ;
    ] .

rc:OrderingKeyShape a sh:NodeShape ;
    sh:targetClass rc:OrderingKey ;
    sh:property [
        sh:path rc:keyColumn ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "OrderingKey must name exactly one keyColumn." ;
    ] ;
    sh:property [
        sh:path rc:keyDirection ;
        sh:maxCount 1 ;
        sh:in ( rc:Ascending rc:Descending ) ;
        sh:message "keyDirection must be Ascending or Descending." ;
    ] ;
    sh:property [
        sh:path rc:keyPrecedence ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "keyPrecedence must be an integer greater than or equal to 1." ;
    ] .

rc:PartitionSchemeShape a sh:NodeShape ;
    sh:targetClass rc:PartitionScheme ;
    sh:property [
        sh:path rc:partitionColumn ;
        sh:nodeKind sh:IRI ;
        sh:message "partitionColumn values should be named column resources." ;
    ] ;
    sh:property [
        sh:path rc:partitionGranularity ;
        sh:maxCount 1 ;
        sh:in ( rc:Daily rc:Hourly rc:Monthly rc:ByValue ) ;
        sh:message "partitionGranularity must be Daily, Hourly, Monthly, or ByValue." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationStatus ;
        sh:maxCount 1 ;
        sh:in (
            rc:UnverifiedLayout
            rc:GeneratedFromManifestLayout
            rc:CandidateLayout
            rc:VerifiedByListingLayout
            rc:VerifiedByQueryLayout
            rc:ContradictedLayout
        ) ;
        sh:message "layoutVerificationStatus must be a known layout verification status." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationNote ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "layoutVerificationNote must be a single string if declared." ;
    ] .

rc:PartitionLevelShape a sh:NodeShape ;
    sh:targetClass rc:PartitionLevel ;
    sh:property [
        sh:path rc:levelPrecedence ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "levelPrecedence must be an integer greater than or equal to 1." ;
    ] ;
    sh:property [
        sh:path rc:levelColumn ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "levelColumn must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:levelGranularity ;
        sh:maxCount 1 ;
        sh:in ( rc:Daily rc:Hourly rc:Monthly rc:ByValue ) ;
        sh:message "levelGranularity must be Daily, Hourly, Monthly, or ByValue." ;
    ] .

rc:StorageAccessShape a sh:NodeShape ;
    sh:targetClass rc:StorageAccess ;
    sh:property [
        sh:path rc:storageProtocol ;
        sh:maxCount 1 ;
        sh:class rc:StorageProtocol ;
        sh:message "storageProtocol must be an rc:StorageProtocol if declared." ;
    ] ;
    sh:property [
        sh:path rc:storageRoot ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "storageRoot must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:locationKind ;
        sh:maxCount 1 ;
        sh:in (
            "object"
            "directory"
            "prefix"
            "connection"
        ) ;
        sh:message "locationKind must be object, directory, prefix, or connection if declared." ;
    ] ;
    sh:property [
        sh:path rc:endpointProfile ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "endpointProfile must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:bucketName ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "bucketName must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:keyPrefix ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "keyPrefix must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:region ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "region must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:pathStyleAccess ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "pathStyleAccess must be a boolean if declared." ;
    ] ;
    sh:property [
        sh:path rc:credentialReference ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "credentialReference must be a non-secret string reference if declared." ;
    ] ;
    sh:property [
        sh:path rc:accessMode ;
        sh:maxCount 1 ;
        sh:class rc:AccessMode ;
        sh:message "accessMode must be an rc:AccessMode if declared." ;
    ] ;
    sh:property [
        sh:path rc:pathTemplate ;
        sh:datatype xsd:string ;
        sh:message "Storage access pathTemplate values must be strings." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationStatus ;
        sh:maxCount 1 ;
        sh:in (
            rc:UnverifiedLayout
            rc:GeneratedFromManifestLayout
            rc:CandidateLayout
            rc:VerifiedByListingLayout
            rc:VerifiedByQueryLayout
            rc:ContradictedLayout
        ) ;
        sh:message "layoutVerificationStatus must be a known layout verification status." ;
    ] ;
    sh:property [
        sh:path rc:layoutVerificationNote ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "layoutVerificationNote must be a single string if declared." ;
    ] .

rc:ObservationShape a sh:NodeShape ;
    sh:targetClass rc:Observation ;
    sh:property [
        sh:path rc:summary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Observation resources must have exactly one string summary." ;
    ] ;
    sh:property [
        sh:path rc:evidence ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Evidence ;
        sh:message "Observation resources should link to at least one named Evidence resource." ;
    ] ;
    sh:property [
        sh:path rc:hasClaim ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Claim ;
        sh:message "hasClaim values should be named Claim resources." ;
    ] ;
    sh:property [
        sh:path rc:observationStatus ;
        sh:maxCount 1 ;
        sh:in ( rc:Tentative rc:Checked rc:Contradicted rc:Promoted ) ;
        sh:message "observationStatus must be Tentative, Checked, Contradicted, or Promoted." ;
    ] ;
    sh:property [
        sh:path rc:observedAt ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "observedAt must be an xsd:dateTime if declared." ;
    ] ;
    sh:property [
        sh:path rc:observedAsset ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "observedAsset should be a named data asset resource." ;
    ] ;
    sh:property [
        sh:path rc:observedColumn ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "observedColumn should be a named column resource." ;
    ] ;
    sh:property [
        sh:path rc:observedColumnName ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "observedColumnName must be a single string if declared." ;
    ] .

rc:ProfileObservationShape a sh:NodeShape ;
    sh:targetClass rc:ProfileObservation ;
    sh:property [
        sh:path rc:sampleSize ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "sampleSize must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:sampleScope ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "sampleScope must be a single string if declared." ;
    ] ;
    sh:property [
        sh:path rc:sampleMethod ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "sampleMethod must be a single string if declared." ;
    ] ;
    sh:property [
        sh:path rc:rowCount ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "rowCount must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:nullCount ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "nullCount must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:distinctCount ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "distinctCount must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:observedValueFrequency ;
        sh:nodeKind sh:IRI ;
        sh:class rc:ObservedValueFrequency ;
        sh:message "observedValueFrequency values should be named ObservedValueFrequency resources." ;
    ] ;
    sh:property [
        sh:path rc:observedProfileMetric ;
        sh:nodeKind sh:IRI ;
        sh:class rc:ObservedProfileMetric ;
        sh:message "observedProfileMetric values should be named ObservedProfileMetric resources." ;
    ] .

rc:ObservedValueFrequencyShape a sh:NodeShape ;
    sh:targetClass rc:ObservedValueFrequency ;
    sh:property [
        sh:path rc:observedValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "ObservedValueFrequency resources must name exactly one observed value." ;
    ] ;
    sh:property [
        sh:path rc:valueFrequency ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "valueFrequency must be a non-negative integer." ;
    ] .

rc:ObservedProfileMetricShape a sh:NodeShape ;
    sh:targetClass rc:ObservedProfileMetric ;
    sh:property [
        sh:path rc:profileMetricKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "ObservedProfileMetric resources must name exactly one profile metric kind." ;
    ] ;
    sh:property [
        sh:path rc:profileMetricTarget ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "profileMetricTarget must be a single IRI when supplied." ;
    ] ;
    sh:property [
        sh:path rc:profileMetricValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "ObservedProfileMetric resources must name exactly one scalar metric value." ;
    ] .

rc:ClaimShape a sh:NodeShape ;
    sh:targetClass rc:Claim ;
    sh:property [
        sh:path rc:claimKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class rc:ClaimKind ;
        sh:message "Claim resources must declare exactly one rc:ClaimKind." ;
    ] ;
    sh:property [
        sh:path rc:claimText ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Claim resources must have exactly one string claimText." ;
    ] ;
    sh:property [
        sh:path rc:claimTarget ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Claim resources should name at least one claimTarget IRI." ;
    ] ;
    sh:property [
        sh:path rc:confidence ;
        sh:maxCount 1 ;
        sh:in ( rc:LowConfidence rc:MediumConfidence rc:HighConfidence ) ;
        sh:message "confidence must be LowConfidence, MediumConfidence, or HighConfidence." ;
    ] ;
    sh:property [
        sh:path rc:observationStatus ;
        sh:maxCount 1 ;
        sh:in ( rc:Tentative rc:Checked rc:Weakened rc:Contradicted rc:Superseded rc:Promoted ) ;
        sh:message "claim observationStatus must be Tentative, Checked, Weakened, Contradicted, Superseded, or Promoted." ;
    ] ;
    sh:property [
        sh:path rc:proposedAssertion ;
        sh:nodeKind sh:IRI ;
        sh:message "proposedAssertion values should be named resources." ;
    ] ;
    sh:property [
        sh:path rc:weakens ;
        sh:nodeKind sh:IRI ;
        sh:message "weakens values should be named resources." ;
    ] ;
    sh:property [
        sh:path rc:contradicts ;
        sh:nodeKind sh:IRI ;
        sh:message "contradicts values should be named resources." ;
    ] ;
    sh:property [
        sh:path rc:supersedes ;
        sh:nodeKind sh:IRI ;
        sh:message "supersedes values should be named resources." ;
    ] ;
    sh:property [
        sh:path rc:refines ;
        sh:nodeKind sh:IRI ;
        sh:message "refines values should be named resources." ;
    ] .

rc:ClaimReconsiderationShape a sh:NodeShape ;
    sh:targetClass rc:ClaimReconsideration ;
    sh:property [
        sh:path rc:summary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "ClaimReconsideration resources must have exactly one string summary." ;
    ] ;
    sh:property [
        sh:path rc:reconsideringClaim ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class rc:Claim ;
        sh:message "ClaimReconsideration resources must name exactly one newer rc:Claim." ;
    ] ;
    sh:property [
        sh:path rc:reconsideredClaim ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class rc:Claim ;
        sh:message "ClaimReconsideration resources must name exactly one older rc:Claim." ;
    ] ;
    sh:property [
        sh:path rc:reconsiderationRelation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( rc:Weakening rc:Contradiction rc:Supersession rc:Refinement ) ;
        sh:message "reconsiderationRelation must be Weakening, Contradiction, Supersession, or Refinement." ;
    ] ;
    sh:property [
        sh:path rc:reconsiderationRationale ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "ClaimReconsideration resources must have exactly one string reconsiderationRationale." ;
    ] ;
    sh:property [
        sh:path rc:reconsideredAt ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "reconsideredAt must be an xsd:dateTime if declared." ;
    ] ;
    sh:property [
        sh:path rc:evidence ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Evidence ;
        sh:message "ClaimReconsideration evidence values should be named Evidence resources." ;
    ] .

rc:PatternShape a sh:NodeShape ;
    sh:targetClass rc:Pattern ;
    sh:or (
        [
            sh:property [
                sh:path rc:supportingObservation ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path rc:supportingClaim ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path rc:evidence ;
                sh:minCount 1 ;
            ]
        ]
    ) ;
    sh:property [
        sh:path rc:summary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Pattern resources must have exactly one string summary." ;
    ] ;
    sh:property [
        sh:path rc:patternText ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Pattern resources must have exactly one string patternText." ;
    ] ;
    sh:property [
        sh:path rc:rationale ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Pattern resources must have exactly one string rationale." ;
    ] ;
    sh:property [
        sh:path rc:patternTarget ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Pattern resources should name at least one patternTarget IRI." ;
    ] ;
    sh:property [
        sh:path rc:supportingObservation ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Observation ;
        sh:message "supportingObservation values should be named Observation resources." ;
    ] ;
    sh:property [
        sh:path rc:supportingClaim ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Claim ;
        sh:message "supportingClaim values should be named Claim resources." ;
    ] ;
    sh:property [
        sh:path rc:evidence ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Evidence ;
        sh:message "Pattern evidence values should be named Evidence resources." ;
    ] ;
    sh:property [
        sh:path rc:confidence ;
        sh:maxCount 1 ;
        sh:in ( rc:LowConfidence rc:MediumConfidence rc:HighConfidence ) ;
        sh:message "Pattern confidence must be LowConfidence, MediumConfidence, or HighConfidence." ;
    ] ;
    sh:property [
        sh:path rc:observationStatus ;
        sh:maxCount 1 ;
        sh:in ( rc:Tentative rc:Checked rc:Weakened rc:Contradicted rc:Superseded rc:Promoted ) ;
        sh:message "Pattern observationStatus must be Tentative, Checked, Weakened, Contradicted, Superseded, or Promoted." ;
    ] ;
    sh:property [
        sh:path rc:patternStability ;
        sh:maxCount 1 ;
        sh:in ( rc:EmergingPattern rc:RepeatedPattern rc:InvariantPattern ) ;
        sh:message "patternStability must be EmergingPattern, RepeatedPattern, or InvariantPattern." ;
    ] ;
    sh:property [
        sh:path rc:synthesizedAt ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "synthesizedAt must be an xsd:dateTime if declared." ;
    ] ;
    sh:property [
        sh:path rc:mapImplication ;
        sh:nodeKind sh:IRI ;
        sh:message "mapImplication values should be named resources." ;
    ] ;
    sh:message "Pattern resources must be supported by observations, claims, or evidence." .

rc:EvidenceShape a sh:NodeShape ;
    sh:targetClass rc:Evidence ;
    sh:or (
        [
            sh:property [
                sh:path dcterms:source ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path rc:sourceSpan ;
                sh:minCount 1 ;
            ]
        ]
    ) ;
    sh:property [
        sh:path rc:summary ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Evidence summary must be a single string if declared." ;
    ] ;
    sh:property [
        sh:path rc:sourceSpan ;
        sh:nodeKind sh:IRI ;
        sh:class rc:SourceSpan ;
        sh:message "sourceSpan values should be named SourceSpan resources." ;
    ] ;
    sh:message "Evidence must identify a source using dcterms:source or rc:sourceSpan." .

rc:SourceSpanShape a sh:NodeShape ;
    sh:targetClass rc:SourceSpan ;
    sh:property [
        sh:path rc:sourcePath ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "SourceSpan must have exactly one string sourcePath." ;
    ] ;
    sh:property [
        sh:path rc:sourceSection ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "sourceSection must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:startLine ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "startLine must be a one-based positive integer." ;
    ] ;
    sh:property [
        sh:path rc:endLine ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "endLine must be a one-based positive integer." ;
    ] ;
    sh:property [
        sh:path rc:sourceKind ;
        sh:maxCount 1 ;
        sh:class rc:SourceKind ;
        sh:message "sourceKind must be an rc:SourceKind if declared." ;
    ] .

rc:GraphRevisionShape a sh:NodeShape ;
    sh:targetClass rc:GraphRevision ;
    sh:property [
        sh:path rc:summary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphRevision resources must have exactly one string summary." ;
    ] ;
    sh:property [
        sh:path rc:revisionType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class rc:RevisionType ;
        sh:message "GraphRevision resources must have exactly one rc:RevisionType." ;
    ] ;
    sh:property [
        sh:path rc:revisionRationale ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphRevision resources must have exactly one string revisionRationale." ;
    ] ;
    sh:property [
        sh:path rc:changedGraph ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphRevision resources must name at least one changedGraph string." ;
    ] ;
    sh:property [
        sh:path rc:includedGraph ;
        sh:datatype xsd:string ;
        sh:message "includedGraph values must be graph role strings." ;
    ] ;
    sh:property [
        sh:path rc:createdAt ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "GraphRevision resources must have exactly one xsd:dateTime createdAt." ;
    ] ;
    sh:property [
        sh:path rc:revisionSupportingObservation ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Observation ;
        sh:message "revisionSupportingObservation values should be named Observation resources." ;
    ] ;
    sh:property [
        sh:path rc:revisionSupportingClaim ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Claim ;
        sh:message "revisionSupportingClaim values should be named Claim resources." ;
    ] ;
    sh:property [
        sh:path rc:revisionSupportingPattern ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Pattern ;
        sh:message "revisionSupportingPattern values should be named Pattern resources." ;
    ] ;
    sh:property [
        sh:path rc:revisionAnchor ;
        sh:nodeKind sh:IRI ;
        sh:message "revisionAnchor values should be named graph resources." ;
    ] ;
    sh:property [
        sh:path rc:revisionStance ;
        sh:maxCount 1 ;
        sh:class rc:RevisionStance ;
        sh:message "revisionStance must be an rc:RevisionStance if declared." ;
    ] ;
    sh:property [
        sh:path rc:alternativeTo ;
        sh:nodeKind sh:IRI ;
        sh:class rc:GraphRevision ;
        sh:message "alternativeTo values should be named GraphRevision resources." ;
    ] ;
    sh:property [
        sh:path rc:restagesRevision ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class rc:GraphRevision ;
        sh:message "restagesRevision should name one earlier staged GraphRevision resource." ;
    ] ;
    sh:property [
        sh:path rc:appliesStagedRevision ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class rc:GraphRevision ;
        sh:message "appliesStagedRevision should name one staged GraphRevision resource." ;
    ] ;
    sh:property [
        sh:path rc:evidence ;
        sh:nodeKind sh:IRI ;
        sh:class rc:Evidence ;
        sh:message "GraphRevision evidence values should be named Evidence resources." ;
    ] ;
    sh:property [
        sh:path rc:hasGraphPatch ;
        sh:nodeKind sh:IRI ;
        sh:class rc:GraphPatch ;
        sh:message "hasGraphPatch values should be named GraphPatch resources." ;
    ] ;
    sh:property [
        sh:path rc:hasGraphSnapshot ;
        sh:nodeKind sh:IRI ;
        sh:class rc:GraphSnapshot ;
        sh:message "hasGraphSnapshot values should be named GraphSnapshot resources." ;
    ] ;
    sh:property [
        sh:path rc:validationConforms ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "validationConforms must be a boolean if declared." ;
    ] ;
    sh:property [
        sh:path rc:validationResultCount ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "validationResultCount must be a non-negative integer if declared." ;
    ] ;
    sh:property [
        sh:path rc:hasValidationResult ;
        sh:nodeKind sh:IRI ;
        sh:class sh:ValidationResult ;
        sh:message "hasValidationResult values should be named SHACL ValidationResult resources." ;
    ] .

rc:ValidationResultShape a sh:NodeShape ;
    sh:targetClass sh:ValidationResult ;
    sh:property [
        sh:path sh:resultMessage ;
        sh:datatype xsd:string ;
        sh:message "Validation result messages must be strings." ;
    ] ;
    sh:property [
        sh:path sh:sourceConstraintComponent ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "sourceConstraintComponent must be a named SHACL constraint component when declared." ;
    ] ;
    sh:property [
        sh:path sh:resultSeverity ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "resultSeverity must be a named SHACL severity when declared." ;
    ] .

rc:GraphPatchShape a sh:NodeShape ;
    sh:targetClass rc:GraphPatch ;
    sh:property [
        sh:path rc:patchOperation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class rc:GraphPatchOperation ;
        sh:message "GraphPatch resources must have exactly one GraphPatchOperation." ;
    ] ;
    sh:property [
        sh:path rc:targetGraph ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphPatch resources must have exactly one string targetGraph." ;
    ] ;
    sh:property [
        sh:path rc:patchFormat ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphPatch resources must have exactly one string patchFormat." ;
    ] ;
    sh:property [
        sh:path rc:patchRole ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class rc:GraphPatchRole ;
        sh:message "GraphPatch resources must have exactly one GraphPatchRole." ;
    ] ;
    sh:property [
        sh:path rc:patchSequence ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "patchSequence must be a one-based integer." ;
    ] ;
    sh:property [
        sh:path rc:patchContent ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphPatch resources must have exactly one string patchContent." ;
    ] ;
    sh:property [
        sh:path rc:patchTripleCount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "patchTripleCount must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:beforeTripleCount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "beforeTripleCount must be a non-negative integer." ;
    ] ;
    sh:property [
        sh:path rc:afterTripleCount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "afterTripleCount must be a non-negative integer." ;
    ] .

rc:GraphSnapshotShape a sh:NodeShape ;
    sh:targetClass rc:GraphSnapshot ;
    sh:property [
        sh:path rc:graphRole ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "GraphSnapshot resources must have exactly one string graphRole." ;
    ] ;
    sh:property [
        sh:path rc:tripleCount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "GraphSnapshot resources must have exactly one non-negative tripleCount." ;
    ] ;
    sh:property [
        sh:path rc:contentDigest ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^sha256:[0-9a-f]{64}$" ;
        sh:message "GraphSnapshot contentDigest must be sha256:<64 lowercase hex characters> when declared." ;
    ] .

rc:KnownCaveatShape a sh:NodeShape ;
    sh:targetClass rc:KnownCaveat ;
    sh:property [
        sh:path rc:caveatDescription ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "caveatDescription must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:impact ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "impact must be a string if declared." ;
    ] ;
    sh:property [
        sh:path rc:severity ;
        sh:maxCount 1 ;
        sh:in ( rc:Minor rc:Moderate rc:Severe ) ;
        sh:message "severity must be Minor, Moderate, or Severe." ;
    ] .

rc:VerificationAttestationShape a sh:NodeShape ;
    sh:targetClass rc:VerificationAttestation ;
    sh:property [
        sh:path rc:verificationTime ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "verificationTime must be an xsd:dateTime if declared." ;
    ] ;
    sh:property [
        sh:path rc:verificationResult ;
        sh:maxCount 1 ;
        sh:in ( rc:Pass rc:Fail rc:Partial rc:Error ) ;
        sh:message "verificationResult must be Pass, Fail, Partial, or Error." ;
    ] ;
    sh:property [
        sh:path rc:verificationDetails ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "verificationDetails must be a string if declared." ;
    ] .
